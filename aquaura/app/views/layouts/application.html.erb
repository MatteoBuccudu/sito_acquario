<!DOCTYPE html>
<html class="scroll-smooth bg-base-100">
  <head>
    <script>
      (function() {
        const theme = localStorage.getItem('theme') || 
                      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <title><%= content_for(:title) || "Sergio | Il Dottore dell'Acqua" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag 'water-drop.png' %>
    <link rel="apple-touch-icon" href="<%= asset_path('water-drop.png') %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <meta name="view-transition" content="same-origin">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap" rel="stylesheet" />
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="animations" class="font-sans antialiased bg-base-100 text-base-content selection:bg-primary/30 selection:text-primary-content">
    

    <!-- Preloader "Livello Acqua" -->
    <div data-controller="preloader" 
         class="fixed inset-0 z-[99990] bg-base-100/80 backdrop-blur-2xl flex flex-col justify-center items-center gap-8 transition-opacity duration-1000 ease-in-out" 
         id="preloader">
      <!-- Rotating Water Drop -->
      <div class="relative flex items-center justify-center">
        <%= image_tag "water-drop.png", class: "animate-[spin_2s_linear_infinite] w-12 h-12 md:w-16 md:h-16 object-contain drop-shadow-[0_0_8px_oklch(var(--p)/0.3)] relative z-10" %>
        <!-- Glowing Pulse behind -->
        <div class="absolute inset-0 bg-primary/20 blur-3xl rounded-full scale-150 animate-pulse"></div>
      </div>
      
      <div class="flex flex-col items-center gap-2">
        <span class="text-base-content/60 text-[0.7rem] md:text-xs uppercase tracking-[0.5em] font-light animate-pulse">
          IMMERSIONE TOTALE
        </span>
        <div class="w-12 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
      </div>
    </div>
    <%= render 'shared/navbar' %>
    <%= render 'shared/search_modal' %>
    <main class="w-full min-h-screen pt-24 md:pt-32">
      <%= yield %>
    </main>
    <%= render 'shared/footer' %>
  </body>
</html>
