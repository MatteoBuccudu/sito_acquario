<!-- D2C Life Science Aesthetic Home Page -->
<div class="w-full font-sans bg-[#0c0c0c] selection:bg-slate-800 selection:text-white pb-32 overflow-hidden text-[#e6e6e6]">
  
  <!-- Preloader Sipario (Simulato via CSS) -->
  <div class="fixed inset-0 z-50 bg-[#0c0c0c] pointer-events-none animate-fade-out-up" style="animation-delay: 1.5s; animation-fill-mode: forwards;"></div>

  <!-- Hero Section DaisyUI -->
  <div class="hero min-h-screen relative" style="background-image: url('https://images.unsplash.com/photo-1522069213448-443a614da9b6?auto=format&fit=crop&q=80&w=2000&h=1200');" data-controller="parallax" data-parallax-speed-value="0.1">
    <div class="hero-overlay bg-base-300 bg-opacity-80 mix-blend-multiply"></div>
    <div class="hero-content text-center text-neutral-content z-10" data-controller="scroll-reveal" class="opacity-0 translate-y-10 transition-all duration-1000">
      <div class="max-w-4xl">
        <h3 class="mb-5 text-sm font-bold uppercase tracking-[0.3em] text-primary">Aquaura &mdash; Studio di Acquariologia</h3>
        
        <h1 class="mb-8 text-5xl md:text-7xl font-serif text-white leading-tight">
          Non costruiamo acquari.<br>
          <span class="text-slate-400 italic font-light">Definiamo mondi sommersi.</span>
        </h1>
        
        <p class="mb-10 text-lg md:text-xl text-slate-300 font-light max-w-2xl mx-auto">
          Progettazione, allestimento e cura di ecosistemi acquatici di lusso. La perfezione della natura, elevata a elemento di interior design.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <%= link_to "Inizia un Progetto", servizi_path, class: "btn btn-primary btn-lg rounded-none uppercase tracking-widest font-semibold text-white" %>
          <%= link_to "Esplora Galleria", galleria_path, class: "btn btn-outline btn-lg rounded-none uppercase tracking-widest text-slate-300 hover:text-white" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Sezione Philosophy (DaisyUI Diff Component x In e Out dell'acqua) -->
  <section class="w-full py-24 md:py-32 bg-base-100 border-t border-white/5">
    <div class="container mx-auto px-6 md:px-12 max-w-6xl">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-16">
        
        <!-- Diff Image (Prima/Dopo l'ingesso d'acqua) -->
        <div class="w-full lg:w-1/2" data-controller="scroll-reveal" class="opacity-0 translate-y-10 transition-all duration-1000 ease-out">
          <div class="diff aspect-[16/9] shadow-2xl border border-white/10">
            <div class="diff-item-1">
              <div class="bg-primary text-primary-content grid place-content-center text-4xl font-serif">Natura Pura</div>
            </div>
            <div class="diff-item-2">
              <div class="bg-base-300 grid place-content-center">
                <img src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&q=80&w=800&h=1000" alt="Iwagumi" class="w-full h-full object-cover filter grayscale-[10%]" />
              </div>
            </div>
            <div class="diff-resizer"></div>
          </div>
        </div>

        <!-- Testo Esteso -->
        <div class="w-full lg:w-1/2 space-y-8" data-controller="scroll-reveal" class="opacity-0 translate-y-10 transition-all duration-1000 delay-200">
          <h2 class="text-4xl lg:text-5xl font-serif text-white leading-tight">
            Dalla biologia<br>all'architettura.
          </h2>
          
          <div class="space-y-6 text-slate-400 font-light leading-relaxed">
            <p>
              Ogni vasca è un'opera d'arte isolata, progettata meticolosamente per fondersi con il tuo ambiente. La geometria scompare, lasciando spazio al quadro fluido della natura.
            </p>
            <p>
              Applichiamo un approccio scientifico rigoroso—dal bilanciamento chimico alla selezione sartoriale di flora e fauna—per garantire una magnificenza duratura col minimo sforzo.
            </p>
          </div>
          
          <div class="pt-4">
            <%= link_to "La nostra Filosofia", blog_index_path, class: "btn btn-outline text-slate-300 hover:text-white rounded-none uppercase tracking-widest text-xs" %>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Sezione Competenze con Mockup & Accordion DaisyUI -->
  <section class="w-full py-24 bg-base-200">
    <div class="container mx-auto px-6 md:px-12 max-w-5xl">
      
      <div class="text-center mb-16" data-controller="scroll-reveal" class="opacity-0 translate-y-10 transition-all duration-1000 ease-out">
        <h2 class="text-4xl md:text-5xl font-serif text-white mb-4">Le Nostre Discipline</h2>
        <p class="text-slate-400 font-light">L'eccellenza operativa dietro ogni nostro ecosistema.</p>
      </div>

      <div class="mockup-window border border-base-300 bg-base-300 shadow-2xl" data-controller="scroll-reveal" class="opacity-0 translate-y-10 transition-all duration-1000 delay-100">
        <div class="flex flex-col justify-center px-4 py-8 bg-base-100 space-y-4">
          
          <!-- Accordion 1 -->
          <div class="collapse collapse-plus bg-base-200 border border-white/5 rounded-box">
            <input type="radio" name="services-accordion" checked="checked" /> 
            <div class="collapse-title text-xl font-serif text-white flex items-center gap-4">
              <span class="text-primary text-sm italic">01</span> Design & Setup
            </div>
            <div class="collapse-content text-slate-400 font-light"> 
              <p>Allestimento chiavi in mano di ecosistemi marini e dolci di altissimo profilo strutturale e biologico. Consulenza architettonica e illuminotecnica inclusa.</p>
            </div>
          </div>

          <!-- Accordion 2 -->
          <div class="collapse collapse-plus bg-base-200 border border-white/5 rounded-box">
            <input type="radio" name="services-accordion" /> 
            <div class="collapse-title text-xl font-serif text-white flex items-center gap-4">
              <span class="text-primary text-sm italic">02</span> Premium Care
            </div>
            <div class="collapse-content text-slate-400 font-light"> 
              <p>Mantenimento periodico totale. Gestiamo i rigidi protocolli chimici, la potatura delle piante e l'alimentazione specifica; il tuo unico compito è ammirare.</p>
            </div>
          </div>

          <!-- Accordion 3 -->
          <div class="collapse collapse-plus bg-base-200 border border-white/5 rounded-box">
            <input type="radio" name="services-accordion" /> 
            <div class="collapse-title text-xl font-serif text-white flex items-center gap-4">
              <span class="text-primary text-sm italic">03</span> Rescue & Rehab
            </div>
            <div class="collapse-content text-slate-400 font-light"> 
              <p>Azioni di salvataggio immediate per ecosistemi compromessi, picchi di ammoniaca o valori chimici critici. Intervento rapido sulle patologie ittiche.</p>
            </div>
          </div>
          
        </div>
      </div>
      
      <div class="text-center mt-12" data-controller="scroll-reveal" class="opacity-0 translate-y-8 transition-all duration-1000 delay-200">
         <%= link_to "Esplora tutti i Servizi", servizi_path, class: "btn border-white/20 text-slate-300 uppercase hover:bg-white hover:text-black transition-colors" %>
      </div>

    </div>
  </section>

</div>
