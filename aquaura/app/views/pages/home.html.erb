<!-- Awwwards-Level Home Page (Pure CSS, Tailwind, DaisyUI & Hotwire) -->
<div class="relative w-full bg-base-100 overflow-hidden font-sans">
  
  <!-- BACKGROUND SOTTOMARINO (Blob Morph & Parallax Nativo) -->
  <div class="fixed inset-0 z-0 pointer-events-none opacity-40 mix-blend-screen bg-fixed bg-center bg-cover" style="background-image: url('https://images.unsplash.com/photo-1522069213448-443a614da9b6?auto=format&fit=crop&q=80&w=2000&h=1200');"></div>
  <!-- Rifrazione della luce nell'acqua (CSS Animato) -->
  <div class="fixed top-[-20%] left-[-10%] w-[50vw] h-[50vw] bg-accent/20 blur-[120px] rounded-full animate-blob-morph z-0 pointer-events-none"></div>
  <div class="fixed bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] bg-primary/20 blur-[150px] rounded-full animate-blob-morph z-0 pointer-events-none" style="animation-delay: -4s;"></div>

  <!-- HERO SECTION (Antigravity & DaisyUI Hero) -->
  <section class="relative z-10 hero min-h-screen bg-transparent pt-20">
    <div class="hero-content text-center text-neutral-content w-full flex-col">
      <div class="max-w-4xl animate-fade-up">
        <h3 class="mb-6 text-xs md:text-sm font-bold uppercase tracking-[0.4em] text-primary">Sergio &mdash; Il Dottore dell'Acqua</h3>
        
        <!-- Kinetic Typography via overflow & tailwind delays -->
        <h1 class="mb-8 text-6xl md:text-8xl font-serif text-white leading-[1.1] tracking-tight">
          <div class="overflow-hidden p-2">
            <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-full transition-transform duration-1000 ease-out">Non costruiamo</div>
          </div>
          <div class="overflow-hidden p-2">
            <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-full transition-transform duration-1000 ease-out delay-100 text-slate-400 italic font-light">Mondi Sommersi.</div>
          </div>
        </h1>
        
        <p class="mb-12 text-lg md:text-2xl text-slate-300 font-light max-w-2xl mx-auto leading-relaxed overflow-hidden">
           <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-full transition-all duration-1000 ease-out delay-200">
             Esaltiamo la natura elevandola a elemento di lusso architettonico.
           </div>
        </p>
        
        <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0 scale-100" class="opacity-0 translate-y-10 scale-95 transition-all duration-700 ease-out delay-300">
          <%= link_to "Inizia un Progetto", servizi_path, class: "btn btn-primary btn-wide rounded-full uppercase tracking-widest font-semibold text-white shadow-[0_0_30px_rgba(14,165,233,0.3)] hover:shadow-[0_0_50px_rgba(14,165,233,0.6)] hover:scale-105 transition-all duration-500 peer" %>
        </div>
      </div>
    </div>
  </section>

  <!-- FILOSOFIA (DaisyUI Diff + Glassmorphism) -->
  <section class="relative z-10 w-full py-32 bg-base-100/60 backdrop-blur-3xl border-t border-white/5">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
        
        <!-- Diff Image (CSS solo nativo DaisyUI) -->
        <div class="w-full lg:w-1/2" data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-20 transition-all duration-1000 ease-out">
          <div class="diff aspect-[4/5] md:aspect-[16/9] lg:aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl border border-white/10 glass animate-float">
            <div class="diff-item-1">
              <div class="bg-primary/20 backdrop-blur-md grid place-content-center text-5xl font-serif text-white">Equilibrio</div>
            </div>
            <div class="diff-item-2">
              <div class="bg-base-300 grid place-content-center">
                <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?auto=format&fit=crop&q=80&w=800&h=1000" alt="Iwagumi Tank" class="w-full h-full object-cover filter grayscale-[20%]" />
              </div>
            </div>
            <div class="diff-resizer"></div>
          </div>
        </div>

        <div class="w-full lg:w-1/2 space-y-10">
          <h2 class="text-5xl lg:text-6xl font-serif text-white leading-tight overflow-hidden">
            <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-full transition-transform duration-1000 ease-out">Dalla Chimica</div>
            <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-full transition-transform duration-1000 ease-out delay-100 text-slate-400 italic">all'Emozione.</div>
          </h2>
          
          <div class="space-y-6 text-xl text-slate-400 font-light leading-relaxed">
            <p data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-10 transition-all duration-1000 ease-out delay-200">
              Il vero lusso è l'assenza di sforzo. Progettiamo veri e propri ecosistemi autonomi dove l'estetica estrema sposa la perfezione biologica.
            </p>
          </div>
          
          <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-300">
             <%= link_to "La nostra Filosofia", blog_index_path, class: "btn btn-outline btn-lg rounded-full border-white/20 text-white uppercase tracking-widest text-sm hover:bg-white hover:text-black transition-colors" %>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- COMPETENZE (Glass Cards & CSS Bob) -->
  <section class="relative z-10 w-full py-32 bg-gradient-to-b from-transparent to-base-100/90">
    <div class="container mx-auto px-6 max-w-7xl">
      
      <div class="text-center mb-24 overflow-hidden">
        <h2 data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="text-5xl md:text-7xl font-serif text-white mb-6 opacity-0 translate-y-full transition-transform duration-1000 ease-out">Le Cure Premium</h2>
      </div>

      <!-- CSS Grid con Staggering via Delay Tailwind -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0 scale-100" class="opacity-0 translate-y-20 scale-95 transition-all duration-1000 ease-out card glass shadow-2xl border border-white/10 hover:border-primary/50 group animate-bob" style="animation-delay: 0s;">
          <div class="card-body gap-6">
            <span class="text-6xl font-serif text-primary/40 group-hover:text-primary transition-colors duration-500">01</span>
            <h3 class="card-title text-3xl font-serif text-white">Architettura Naturale</h3>
            <p class="text-slate-400 font-light leading-relaxed">Design estremo, integrazione architettonica e illuminotecnica su misura per installazioni museali.</p>
          </div>
          <figure class="px-8 pb-8">
             <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden">
               <div class="w-0 h-full bg-primary group-hover:w-full transition-all duration-1000 ease-in-out"></div>
             </div>
          </figure>
        </div>

        <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0 scale-100" class="opacity-0 translate-y-20 scale-95 transition-all duration-1000 ease-out delay-100 card glass shadow-2xl border border-white/10 hover:border-accent/50 group animate-bob" style="animation-delay: 1.5s;">
          <div class="card-body gap-6">
             <span class="text-6xl font-serif text-accent/40 group-hover:text-accent transition-colors duration-500">02</span>
            <h3 class="card-title text-3xl font-serif text-white">Mantenimento Totale</h3>
            <p class="text-slate-400 font-light leading-relaxed">Assenza totale di oneri per il cliente. Gestiamo la biochimica e la salute della fauna con screening periodici.</p>
          </div>
          <figure class="px-8 pb-8">
             <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden">
               <div class="w-0 h-full bg-accent group-hover:w-full transition-all duration-1000 ease-in-out"></div>
             </div>
          </figure>
        </div>

        <div data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0 scale-100" class="opacity-0 translate-y-20 scale-95 transition-all duration-1000 ease-out delay-200 card glass shadow-2xl border border-white/10 hover:border-error/50 group animate-bob" style="animation-delay: 3s;">
          <div class="card-body gap-6">
             <span class="text-6xl font-serif text-error/40 group-hover:text-error transition-colors duration-500">03</span>
            <h3 class="card-title text-3xl font-serif text-white">ER Sotterraneo</h3>
            <p class="text-slate-400 font-light leading-relaxed">Pronto intervento avanzato H24 per crisi di sistema, squilibri algali e salvataggio coralli.</p>
          </div>
          <figure class="px-8 pb-8">
             <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden">
               <div class="w-0 h-full bg-error group-hover:w-full transition-all duration-1000 ease-in-out"></div>
             </div>
          </figure>
        </div>

      </div>
      
      <div class="text-center mt-20" data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-y-0" class="opacity-0 translate-y-10 transition-all duration-1000 ease-out delay-300">
         <%= link_to "Esplora i Trattamenti", servizi_path, class: "btn btn-ghost rounded-full uppercase tracking-widest text-slate-300 hover:text-white" %>
      </div>

    </div>
  </section>

</div>
