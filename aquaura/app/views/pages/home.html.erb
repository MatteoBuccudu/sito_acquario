<!-- Home Page: Deep Sea Luxury Edition -->
<div class="relative w-full bg-base-100 overflow-hidden font-sans selection:bg-primary/40">
  
  <!-- UNDERWATER CORE BACKGROUND -->
  <!-- Dynamic Gradient -->
  <div class="fixed inset-0 z-0 bg-gradient-to-b from-base-200 via-base-100 to-base-200"></div>
  
  <!-- Surface Shimmer (Caustics) -->
  <div class="fixed inset-0 z-0 opacity-20 pointer-events-none animate-caustics" 
       style="background-image: url('https://www.transparenttextures.com/patterns/water.png'); background-size: 500px;"></div>

  <!-- BUBBLES SYSTEM (Native CSS) -->
  <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
    <% 20.times do |i| %>
      <div class="absolute bottom-0 rounded-full bg-primary/10 blur-[1px] animate-bubble-rise"
           style="left: <%= rand(5..95) %>%; 
                  width: <%= w = rand(4..12) %>px; 
                  height: <%= w %>px; 
                  animation-delay: <%= rand(0..8) %>s; 
                  animation-duration: <%= rand(4..7) %>s;
                  opacity: <%= rand(0.1..0.4) %>;">
      </div>
    <% end %>
  </div>

  <%= render "shared/faq" %>
</div>



  <!-- Rifrazione della luce nell'acqua (Fluid Blobs) -->
  <div class="fixed top-[-10%] left-[-5%] w-[60vw] h-[60vw] bg-primary/10 blur-[120px] rounded-full animate-blob-morph z-0 pointer-events-none"></div>
  <div class="fixed bottom-[-10%] right-[-5%] w-[70vw] h-[70vw] bg-secondary/20 blur-[150px] rounded-full animate-blob-morph z-0 pointer-events-none" style="animation-delay: -4s;"></div>

  <!-- HERO SECTION: DAISYUI CLASSIC STRUCTURE -->
  <section class="hero min-h-screen relative z-10 overflow-hidden" 
           style="background-image: url('https://images.unsplash.com/photo-1524704659690-3f8037f7f96d?auto=format&fit=crop&q=80&w=2000');">
    <div class="hero-overlay bg-base-100/70 backdrop-blur-[2px]"></div>
    <div class="hero-content text-center text-base-content">
      <div class="max-w-4xl reveal">
        
        <!-- Badge -->
        <div class="inline-block mb-8 px-6 py-2 rounded-full border border-primary/30 bg-primary/5 backdrop-blur-md">
           <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.5em] text-primary">
             Sergio &mdash; L'Eccellenza Sommersa
           </span>
        </div>
        
        <!-- Main Title with Robust "Slide & Glow" Rotation -->
        <h1 class="reveal mb-10 text-5xl md:text-8xl font-serif font-bold tracking-tight h-32 md:h-48 flex items-center justify-center overflow-visible">
          <div class="text-rotate w-full relative h-full flex items-center justify-center px-10 overflow-visible">
            <span class="italic font-light text-primary whitespace-nowrap">Puro Silenzio.</span>
            <span class="italic font-light text-secondary whitespace-nowrap">Profonda Emozione.</span>
            <span class="italic font-light text-accent whitespace-nowrap">Lusso Acquatico.</span>
            <span class="italic font-light text-base-content whitespace-nowrap">Architettura Viva.</span>
          </div>
        </h1>
        
        <p class="reveal mb-12 text-xl md:text-2xl text-base-content/80 font-light max-w-2xl mx-auto leading-relaxed">
          Creiamo ecosistemi di lusso che respirano con te. Un'esperienza sensoriale dove l'acqua diventa pura forma d'arte architettonica.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <%= link_to "Esplora il Lusso", servizi_path, class: "btn btn-primary btn-lg rounded-full px-12 group transition-all duration-500 hover:scale-105 shadow-[0_0_40px_rgba(var(--color-primary),0.3)]" %>
          <%= link_to "Guarda le Opere", galleria_path, class: "btn btn-ghost btn-lg rounded-full px-12 text-base-content/70 hover:text-base-content transition-all underline underline-offset-8 decoration-primary/30 hover:decoration-primary" %>
        </div>
      </div>
    </div>

    <!-- Scroll Down indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-40">
      <div class="w-px h-20 bg-gradient-to-b from-base-content to-transparent"></div>
    </div>
  </section>

  <!-- FILOSOFIA: "Sotto il Pelo dell'Acqua" -->
  <section class="relative z-10 w-full py-40 bg-base-200/40 backdrop-blur-sm border-y border-base-content/5">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="flex flex-col lg:flex-row items-center gap-20">
        
        <!-- Image with Custom Frame -->
        <div class="w-full lg:w-1/2 relative group reveal opacity-0 -translate-x-20 transition-all duration-1000" data-controller="scroll-reveal" data-scroll-reveal-reveal-class="opacity-100 translate-x-0">
          <div class="relative z-10 rounded-[3rem] overflow-hidden aspect-[4/5] shadow-2xl transition-transform duration-700 group-hover:scale-[1.02]">
            <img src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&q=80&w=1200" alt="Deep Sea Life" class="w-full h-full object-cover scale-110 transition-transform duration-[10s] group-hover:scale-125" />
            <div class="absolute inset-0 bg-gradient-to-t from-base-100/80 via-transparent to-transparent"></div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -top-10 -right-10 w-40 h-40 border-t border-r border-primary/20 rounded-tr-[4rem] pointer-events-none"></div>
          <div class="absolute -bottom-10 -left-10 w-40 h-40 border-b border-l border-primary/20 rounded-bl-[4rem] pointer-events-none"></div>
        </div>

        <div class="w-full lg:w-1/2 space-y-12">
          <div class="space-y-4">
            <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm block">La nostra Visione</span>
            <h2 class="reveal text-5xl lg:text-7xl font-serif text-base-content tracking-tight leading-[1.1]">
              Equilibrio <br/>
              <span class="text-base-content/40 italic font-light">senza compromessi.</span>
            </h2>
          </div>
          
          <p class="reveal text-xl text-base-content/60 font-light leading-relaxed max-w-xl">
            Non siamo semplici installatori. Siamo architetti della vita. Ogni progetto è una sfida alla chimica e un inno alla pace interiore, consegnato chiavi in mano per chi non accetta meno della perfezione.
          </p>
          
          <div class="grid grid-cols-2 gap-10 pt-6">
            <div class="space-y-2">
              <span class="text-4xl font-serif text-base-content">#1</span>
              <p class="text-xs uppercase tracking-widest text-primary font-bold">In Italia</p>
            </div>
            <div class="space-y-2">
              <span class="text-4xl font-serif text-base-content">0%</span>
              <p class="text-xs uppercase tracking-widest text-primary font-bold">Intervento Cliente</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVIZI PREMIUM: 3D HOVER EXPERIENCE -->
  <section class="relative z-10 w-full py-40">
    <div class="container mx-auto px-6 max-w-[90rem]">
      
      <div class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8 px-4">
        <div class="reveal max-w-2xl">
          <h2 class="text-5xl md:text-7xl font-serif text-base-content mb-6">Trattamenti d'Elite</h2>
          <p class="text-base-content/60 text-lg leading-relaxed italic">Esperienze sensoriali e bio-gestione avanzata. Il lusso del tempo ritrovato.</p>
        </div>
        <%= link_to "Tutti i Servizi", servizi_path, class: "btn btn-outline btn-primary rounded-full px-10 border-primary/30 hover:bg-primary hover:text-primary-content transition-all duration-500 uppercase tracking-widest text-xs font-bold" %>
      </div>

      <!-- Grid for 4 3D Cards -->
  <div class="stagger-reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

    <% # ─── CARD 1: Aquascaping D'Autore ─── %>
    <div class="tooltip tooltip-bottom tooltip-primary w-72" data-tip="Ogni acquario è un progetto unico, mai replicato">
      <div class="hover-3d">
        <div class="card image-full rounded-2xl overflow-hidden shadow-2xl h-[520px]">
          <figure class="h-full">
            <img
              src="https://images.pexels.com/photos/10519036/pexels-photo-10519036.jpeg?auto=compress&cs=tinysrgb&w=600"
              alt="Aquascape con piante sommerse"
              class="w-full h-full object-cover"
            />
          </figure>
          <div class="card-body p-6 flex flex-col justify-between">

            <div class="flex justify-between items-center">
              <span class="badge badge-soft badge-accent text-[0.6rem] tracking-widest uppercase">Aquascaping</span>
              <span class="badge badge-warning badge-soft badge-sm">★ Premium</span>
            </div>

            <div class="flex-1 flex flex-col justify-center gap-3 py-4">
              <h2 class="card-title text-white text-xl leading-snug">
                Design Sommerso<br/>Su Misura
              </h2>
              <p class="text-white/65 text-sm leading-relaxed">
                Non un semplice acquario, ma un'opera d'arte viva. Progettiamo layout con rocce rare, legni pregiati e piante vere, integrando sistemi di illuminazione LED a spettro completo per una crescita rigogliosa e colori vibranti.
              </p>
            </div>

            <div class="flex flex-col gap-3">
              <div>
                <div class="flex justify-between mb-1.5">
                  <span class="text-white/50 text-[0.6rem] tracking-widest uppercase">Soddisfazione clienti</span>
                  <span class="text-white/70 text-xs">98%</span>
                </div>
                <progress class="progress progress-accent w-full h-1.5" value="98" max="100"></progress>
              </div>
              <a href="#" class="btn btn-accent btn-sm btn-block rounded-xl text-xs tracking-wide">
                Esplora le Opere →
              </a>
            </div>

          </div>
        </div>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
    </div>

    <% # ─── CARD 2: Bio-Remote 24/7 ─── %>
    <div class="tooltip tooltip-bottom tooltip-primary w-72" data-tip="Monitoraggio remoto H24 con alert immediati su smartphone">
      <div class="hover-3d">
        <div class="card image-full rounded-2xl overflow-hidden shadow-2xl h-[520px]">
          <figure class="h-full">
            <img
              src="https://images.pexels.com/photos/2280549/pexels-photo-2280549.jpeg?auto=compress&cs=tinysrgb&w=600"
              alt="Provette laboratorio analisi acqua"
              class="w-full h-full object-cover"
            />
          </figure>
          <div class="card-body p-6 flex flex-col justify-between">

            <div class="flex justify-between items-center">
              <span class="badge badge-soft badge-info text-[0.6rem] tracking-widest uppercase">Bio-Remote</span>
              <div class="flex items-center gap-1.5">
                <span class="status status-success status-sm"></span>
                <span class="text-white/65 text-xs">Live 24/7</span>
              </div>
            </div>

            <div class="flex-1 flex flex-col justify-center gap-3 py-4">
              <h2 class="card-title text-white text-xl leading-snug">
                Controllo Chimico<br/>Intelligente
              </h2>
              <p class="text-white/65 text-sm leading-relaxed">
                Monitoriamo i tuoi valori da remoto. Gestione computerizzata di pH, temperatura e livelli di CO2. Interveniamo prima che i nitriti salgano, garantendo un ciclo dell'azoto perfetto e un ambiente stabile per i tuoi pesci più delicati.
              </p>
            </div>

            <div class="flex flex-col gap-3">
              <div class="grid grid-cols-3 gap-2">
                <div class="bg-black/40 rounded-xl p-2.5 text-center">
                  <div class="text-info font-bold text-base">7.2</div>
                  <div class="text-white/40 text-[0.6rem] mt-0.5">pH</div>
                </div>
                <div class="bg-black/40 rounded-xl p-2.5 text-center">
                  <div class="text-success font-bold text-base">24°</div>
                  <div class="text-white/40 text-[0.6rem] mt-0.5">Temp.</div>
                </div>
                <div class="bg-black/40 rounded-xl p-2.5 text-center">
                  <div class="text-warning font-bold text-base">30</div>
                  <div class="text-white/40 text-[0.6rem] mt-0.5">CO₂</div>
                </div>
              </div>
              <a href="#" class="btn btn-info btn-sm btn-block rounded-xl text-xs tracking-wide">
                Scopri il Sistema →
              </a>
            </div>

          </div>
        </div>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
    </div>

    <% # ─── CARD 3: Rescue & Recovery ─── %>
    <div class="tooltip tooltip-bottom tooltip-primary w-72" data-tip="Intervento d'emergenza entro 4 ore dalla chiamata">
      <div class="hover-3d">
        <div class="card image-full rounded-2xl overflow-hidden shadow-2xl h-[520px]">
          <figure class="h-full">
            <img
              src="https://images.pexels.com/photos/220213/pexels-photo-220213.jpeg?auto=compress&cs=tinysrgb&w=600"
              alt="Goccia d'acqua pura osmosi inversa"
              class="w-full h-full object-cover"
            />
          </figure>
          <div class="card-body p-6 flex flex-col justify-between">

            <div class="flex justify-between items-center">
              <span class="badge badge-soft badge-error text-[0.6rem] tracking-widest uppercase">Rescue</span>
              <div class="flex items-center gap-1.5">
                <span class="status status-error status-sm"></span>
                <span class="text-white/65 text-xs">Entro 4h</span>
              </div>
            </div>

            <div class="flex-1 flex flex-col justify-center gap-3 py-4">
              <h2 class="card-title text-white text-xl leading-snug">
                Pronto Intervento<br/>Biologico
              </h2>
              <p class="text-white/65 text-sm leading-relaxed">
                Hai l'acqua torbida o pesci sofferenti? Il nostro team interviene a domicilio per ripristinare l'equilibrio. Utilizziamo acqua da osmosi inversa pura e biocondizionatori professionali per salvare il tuo ecosistema in tempi record.
              </p>
            </div>

            <div class="flex flex-col gap-3">
              <div role="alert" class="alert alert-error alert-soft py-2.5 px-3.5 text-xs rounded-xl">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
                Tasso di recupero ecosistemi: 96%
              </div>
              <a href="#" class="btn btn-error btn-sm btn-block rounded-xl text-xs tracking-wide">
                Richiedi Soccorso →
              </a>
            </div>

          </div>
        </div>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
    </div>

    <% # ─── CARD 4: Architecture Integration ─── %>
    <div class="tooltip tooltip-bottom tooltip-primary w-72" data-tip="Acquari su misura integrati nell'architettura del tuo spazio">
      <div class="hover-3d">
        <div class="card image-full rounded-2xl overflow-hidden shadow-2xl h-[520px]">
          <figure class="h-full">
            <img
              src="https://images.pexels.com/photos/6758359/pexels-photo-6758359.jpeg?auto=compress&cs=tinysrgb&w=600"
              alt="Acquario integrato in arredamento di lusso"
              class="w-full h-full object-cover"
            />
          </figure>
          <div class="card-body p-6 flex flex-col justify-between">

            <div class="flex justify-between items-center">
              <span class="badge badge-soft badge-secondary text-[0.6rem] tracking-widest uppercase">Luxury</span>
              <span class="badge badge-ghost badge-sm">◆ Su misura</span>
            </div>

            <div class="flex-1 flex flex-col justify-center gap-3 py-4">
              <h2 class="card-title text-white text-xl leading-snug">
                Acquari Strutturali<br/>di Lusso
              </h2>
              <p class="text-white/65 text-sm leading-relaxed">
                Integriamo l'acquariologia professionale nell'arredamento di alta classe. Dalle pareti divisorie trasparenti ai mobili di design, curiamo ogni dettaglio tecnico affinché la tecnologia sia invisibile e l'emozione sia totale.
              </p>
            </div>

            <div class="flex flex-col gap-3">
              <div class="grid grid-cols-2 gap-2">
                <div class="bg-black/40 rounded-xl p-2.5 text-center">
                  <div class="text-secondary font-bold text-base">5.000L</div>
                  <div class="text-white/40 text-[0.6rem] mt-0.5">Max volume</div>
                </div>
                <div class="bg-black/40 rounded-xl p-2.5 text-center">
                  <div class="text-accent font-bold text-base">360°</div>
                  <div class="text-white/40 text-[0.6rem] mt-0.5">Visuale</div>
                </div>
              </div>
              <a href="#" class="btn btn-secondary btn-sm btn-block rounded-xl text-xs tracking-wide">
                Progetta con Noi →
              </a>
            </div>

          </div>
        </div>
        <div></div><div></div><div></div><div></div>
        <div></div><div></div><div></div><div></div>
      </div>
    </div>

  </div>