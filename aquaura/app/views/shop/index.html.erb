        <li class="step step-secondary"><span class="mt-3 text-xs text-base-content/60">Intervento</span></li>
        <li class="step"><span class="mt-3 text-xs text-base-content/60">Report finale</span></li>
        <li class="step"><span class="mt-3 text-xs text-base-content/60">Monitoraggio</span></li>
