<%# ══════════════════════════════════════════════════════
    Servizi — "SOS Sergio"
    DaisyUI 5 + Tailwind + 3D Hover JS
══════════════════════════════════════════════════════ %>

<style>
  .tilt-card { transform-style: preserve-3d; will-change: transform; }
  @keyframes fade-up-local {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { opacity: 0; animation: fade-up-local 0.7s ease forwards; animation-play-state: paused; }
  @keyframes pulse-ring {
    0%   { box-shadow: 0 0 0 0 oklch(var(--color-error)/0.4); }
    70%  { box-shadow: 0 0 0 12px oklch(var(--color-error)/0); }
    100% { box-shadow: 0 0 0 0 oklch(var(--color-error)/0); }
  }
  .sos-ring { animation: pulse-ring 2.5s ease-in-out infinite; }
  @keyframes float-local {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
  }
  .float-anim { animation: float-local 4s ease-in-out infinite; }
</style>

<div class="min-h-screen bg-base-100 overflow-x-hidden">

  <%# ── HERO ─────────────────────────────────────────── %>
  <section class="relative pt-28 pb-20 px-6 overflow-hidden">
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[700px] h-[300px]
                rounded-full bg-error/5 blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <div class="float-anim inline-block mb-8">
        <div class="sos-ring w-20 h-20 rounded-full bg-error/10 border-2 border-error/30
                    flex items-center justify-center text-3xl mx-auto">
          🆘
        </div>
      </div>
      <div class="badge badge-error badge-outline badge-lg mb-6 fade-up" style="animation-delay:0.1s;">
        Intervento Rapido
      </div>
      <h1 class="text-6xl lg:text-7xl font-black tracking-tighter mb-4 leading-[0.9] fade-up" style="animation-delay:0.2s;">
        SOS<br>
        <span class="text-primary">Sergio</span>
      </h1>
      <p class="text-base-content/50 text-xl font-light leading-relaxed max-w-xl mx-auto fade-up" style="animation-delay:0.35s;">
        Qualcosa non va nella tua vasca? Non lasciare che il problema peggiori.
        Siamo qui per rassicurarti, con metodo e precisione.
      </p>
    </div>
  </section>

  <%# ── ALERT URGENZA ───────────────────────────────── %>
  <div class="max-w-5xl mx-auto px-6 mb-10">
    <div role="alert" class="alert alert-warning alert-soft sm:alert-horizontal rounded-2xl">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      <span class="text-sm"><strong>Emergenza in corso?</strong> Scrivi subito a Sergio su WhatsApp. Risposta garantita entro 10 minuti.</span>
      <a href="https://wa.me/393273030230" class="btn btn-sm btn-warning rounded-xl text-[0.65rem] tracking-widest uppercase">WhatsApp</a>
    </div>
  </div>

  <%# ── SERVIZI ─────────────────────────────────────── %>
  <section class="max-w-5xl mx-auto px-6 pb-20 space-y-6">
    <%
      servizi = [
        {
          num:"01", colore:"primary", emoji:"🔬",
          titolo:"Check-up Chimico Completo",
          sotto:"Il tuo acquario sotto analisi professionale",
          desc:"Analizziamo 12 parametri con fotometro professionale. Ti consegniamo un report digitale con il piano correttivo personalizzato.",
          lista:["12 parametri: NH₃, NO₂, NO₃, PO₄, GH, KH, pH, CO₂", "Fotometro professionale — non striscette", "Report PDF con piano correttivo step-by-step", "Consulenza post-analisi inclusa"],
          prezzo:"da € 89", step_color:"step-primary",
          alert_type: "alert-info",
          nota: "Disponibile anche da remoto con tuo kit di prelievo.",
        },
        {
          num:"02", colore:"success", emoji:"✂️",
          titolo:"Potatura & Aquascaping",
          sotto:"Le piante hanno preso il sopravvento?",
          desc:"Potatura, riordino e rinvigoriamo il tuo layout mantenendo lo stile originale. Forbici curve, pinze pro e occhio da artista.",
          lista:["Potatura selettiva con forbici curve professionali", "Riposizionamento rocce e radici", "Trattamento antialghe post-intervento", "Consulenza su piantumazione futura"],
          prezzo:"da € 120", step_color:"step-success",
          alert_type: "alert-success",
          nota: "Prima e dopo fotografati e inclusi nel report.",
        },
        {
          num:"03", colore:"warning", emoji:"🚚",
          titolo:"Trasloco Acquario",
          sotto:"Sposti casa? Pensiamo a tutto noi.",
          desc:"Gestiamo trasporto pesci in sicurezza e riallestimento tecnico, evitando lo shock osmotico. Zero stress per te e per i tuoi abitanti.",
          lista:["Sacchetti con ossigeno puro e antiossidante", "Contenitori termici per il trasporto", "Riallestimento completo nella nuova sede", "Monitoraggio parametri nelle 48h successive"],
          prezzo:"da € 200", step_color:"step-warning",
