    <%# ── CHAT TESTIMONIANZE ─────────────────────────── %>
    <div class="mt-16">
      <div class="divider divider-primary opacity-30 mb-10">
        <span class="text-[0.65rem] tracking-[0.3em] uppercase text-base-content/30 font-semibold">Conversazioni reali</span>
