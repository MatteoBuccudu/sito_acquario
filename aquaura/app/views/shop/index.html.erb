          <div class="chat-header text-xs opacity-50 mb-1">Cliente · ieri sera</div>
          <div class="chat-bubble chat-bubble-neutral text-sm">Sergio i miei Discus boccheggiano tutti in superficie, cosa faccio?? 😱</div>
        </div>
        <div class="chat chat-end">
          <div class="chat-image avatar"><div class="w-8 rounded-full bg-primary flex items-center justify-center text-sm">S</div></div>
          <div class="chat-header text-xs opacity-50 mb-1">Sergio · 8 min dopo</div>
          <div class="chat-bubble chat-bubble-primary text-sm">Tranquillo! Misurami subito il pH e l'ossigeno disciolto. Probabilmente è un calo di O₂ notturno. Ti dico cosa fare step by step 👌</div>
        </div>
        <div class="chat chat-start">
          <div class="chat-image avatar"><div class="w-8 rounded-full bg-base-300 flex items-center justify-center text-sm">👤</div></div>
          <div class="chat-bubble chat-bubble-neutral text-sm">pH 7.0, non ho il test O₂... 😬</div>
        </div>
        <div class="chat chat-end">
          <div class="chat-image avatar"><div class="w-8 rounded-full bg-primary flex items-center justify-center text-sm">S</div></div>
          <div class="chat-bubble chat-bubble-primary text-sm">Ok, alza le pompe al 100%, metti un'aeratore d'emergenza e apri il coperchio. Domani mattina tutto ok, garantito ✅</div>
        </div>
      </div>
    </div>

    <%# ── GARANZIA ─────────────────────────────────────── %>
    <div class="mt-10 p-8 rounded-3xl bg-primary/5 border border-primary/20 text-center fade-up" style="animation-delay:0.2s;">
      <p class="text-5xl mb-4">🛡️</p>
      <h3 class="text-xl font-black text-base-content mb-2">Garanzia Soddisfatti o Ri-analizziamo</h3>
      <p class="text-base-content/50 text-sm max-w-lg mx-auto">
        Se dopo il nostro intervento i parametri non rientrano nei range promessi, torniamo gratuitamente. Punto.
      </p>
    </div>
  </section>
</div>

<script>
  (function() {
    function initTilt() {
      document.querySelectorAll('[data-tilt]').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r = card.getBoundingClientRect();
          const rx = ((e.clientY - r.top  - r.height/2) / (r.height/2)) * -8;
          const ry = ((e.clientX - r.left - r.width /2) / (r.width /2)) *  8;
          card.style.transform = `perspective(1200px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.015,1.015,1.015)`;
          card.style.boxShadow = `${-ry*3}px ${rx*3}px 50px rgba(0,0,0,0.18)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.5s ease, box-shadow 0.5s ease';
          card.style.transform = 'perspective(1200px) rotateX(0) rotateY(0) scale3d(1,1,1)';
          card.style.boxShadow = '';
          setTimeout(() => { card.style.transition = ''; }, 500);
        });
      });
    }

    function initReveal() {
      const obs = new IntersectionObserver(es => es.forEach(e => { 
        if(e.isIntersecting){ 
          e.target.style.animationPlayState = 'running'; 
          obs.unobserve(e.target);
        } 
      }), {threshold:0.1});
      document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
    }

    // Run on load and on Turbo frame/page changes
    document.addEventListener('turbo:load', () => {
      initTilt();
      initReveal();
    });
    
    // Initial run
    initTilt();
    initReveal();
  })();
</script>
