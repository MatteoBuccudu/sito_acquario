<%# ══════════════════════════════════════════════════════
    Shop — I Kit "Segreti di Sergio"
    DaisyUI 5 + Tailwind + 3D Hover JS
══════════════════════════════════════════════════════ %>

<style>
  .tilt-card { transform-style: preserve-3d; will-change: transform; }
  .card-z    { transform: translateZ(20px); }
  .card-z-sm { transform: translateZ(10px); }

  @keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }
  .shimmer-text {
    background: linear-gradient(90deg, oklch(var(--p)) 0%, oklch(var(--s)) 40%, oklch(var(--a)) 70%, oklch(var(--p)) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }
  @keyframes bubble {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.35; }
    50%       { transform: translateY(-20px) scale(1.1); opacity: 0.65; }
  }
  .bubble-anim { animation: bubble ease-in-out infinite; }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 20px -5px oklch(var(--p)/0.35); }
    50%       { box-shadow: 0 0 45px  0px oklch(var(--p)/0.65); }
  }
  .glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .spin-slow { animation: spin-slow 22s linear infinite; }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { opacity: 0; animation: fade-up 0.7s ease forwards; animation-play-state: paused; }
</style>

<div class="min-h-screen bg-base-100 overflow-x-hidden">

  <%# ── HERO ─────────────────────────────────────────── %>
  <section class="relative pt-28 pb-20 px-6 overflow-hidden">
    <div class="spin-slow absolute top-20 right-12 w-64 h-64 rounded-full border border-primary/10 hidden lg:block pointer-events-none"></div>
    <div class="spin-slow absolute top-32 right-24 w-40 h-40 rounded-full border border-secondary/10 hidden lg:block pointer-events-none" style="animation-direction:reverse;animation-duration:14s;"></div>
    <% [[8,4,5],[22,5,7],[35,3,6],[68,6,8],[80,4,7],[92,3,5]].each_with_index do |(l,s,d),i| %>
      <div class="bubble-anim absolute bottom-6 rounded-full bg-primary/20 pointer-events-none"
           style="left:<%= l %>%;width:<%= s %>px;height:<%= s %>px;animation-duration:<%= d %>s;animation-delay:<%= i * 0.9 %>s;"></div>
    <% end %>
    <div class="relative max-w-4xl mx-auto text-center">
      <div class="badge badge-primary badge-outline badge-lg mb-8 fade-up" style="animation-delay:0.1s;">
        ✦ Selezione Curata da Sergio
      </div>
      <h1 class="text-6xl lg:text-7xl font-black tracking-tighter mb-4 leading-[0.9] fade-up" style="animation-delay:0.2s;">
        I Kit<br><span class="shimmer-text">Segreti di Sergio</span>
      </h1>
      <p class="text-base-content/50 text-xl font-light leading-relaxed max-w-xl mx-auto mb-10 fade-up" style="animation-delay:0.35s;">
        Non vendiamo flaconi. Vendiamo il <strong class="text-base-content/80 font-semibold">risultato</strong>.
      </p>
      <div class="stats stats-horizontal bg-base-200/60 border border-base-300 rounded-3xl shadow-lg backdrop-blur-sm fade-up" style="animation-delay:0.5s;">
        <div class="stat place-items-center px-8">
          <div class="stat-value text-primary text-3xl">3</div>
          <div class="stat-desc tracking-widest uppercase text-xs">Kit disponibili</div>
        </div>
        <div class="stat place-items-center px-8">
          <div class="stat-value text-secondary text-3xl">7</div>
          <div class="stat-desc tracking-widest uppercase text-xs">Giorni risultato</div>
        </div>
        <div class="stat place-items-center px-8">
          <div class="stat-value text-accent text-3xl">4.9</div>
          <div class="stat-desc tracking-widest uppercase text-xs">★ Valutazione</div>
        </div>
      </div>
    </div>
  </section>

  <%# ── ALERT PROMO ─────────────────────────────────── %>
  <div class="max-w-7xl mx-auto px-6 mb-10">
    <div role="alert" class="alert alert-info alert-soft sm:alert-horizontal rounded-2xl">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span class="text-sm"><strong>Offerta Marzo:</strong> Acquista 2 kit e ricevi una consulenza WhatsApp gratuita di 30 minuti.</span>
      <button class="btn btn-sm btn-info rounded-xl text-[0.65rem] tracking-widest uppercase">Scopri</button>
    </div>
  </div>

  <%# ── PRODOTTI GRID ────────────────────────────────── %>
  <section class="max-w-7xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <%# KIT 1 %>
      <div class="tilt-card cursor-pointer" data-tilt>
        <div class="card bg-base-200 border border-base-300 hover:border-primary/40 overflow-hidden h-full"
             style="transform-style:preserve-3d;">
          <figure class="relative h-44 bg-gradient-to-br from-primary/10 to-primary/5">
            <div class="absolute inset-0 flex items-center justify-center text-8xl opacity-30">💧</div>
            <div class="absolute top-4 left-4"><span class="badge badge-primary badge-sm font-bold tracking-widest uppercase">Startup</span></div>
            <div class="absolute top-4 right-4"><span class="badge badge-ghost badge-sm font-mono">KIT-01</span></div>
            <div class="absolute inset-0 bg-gradient-to-t from-base-200 via-transparent to-transparent"></div>
          </figure>
          <div class="card-body gap-4">
            <div style="transform:translateZ(18px);">
              <h2 class="card-title text-xl font-black">Kit "Acqua Cristallina"</h2>
              <p class="text-base-content/50 text-sm italic mt-1 leading-relaxed">"Trasforma l'acqua del rubinetto in un habitat sicuro in soli 7 giorni."</p>
            </div>
            <div class="divider divider-primary my-0 opacity-20"></div>
            <ul class="steps steps-vertical text-xs">
              <li class="step step-primary" data-content="1"><span class="ml-2 text-xs text-base-content/70">Biocondizionatore a rilascio graduale</span></li>
              <li class="step step-primary" data-content="2"><span class="ml-2 text-xs text-base-content/70">Fiale batteri nitrificanti</span></li>
              <li class="step step-primary" data-content="3"><span class="ml-2 text-xs text-base-content/70">Test reagente NO₂ e NO₃</span></li>
            </ul>
            <div class="divider my-0 opacity-20"></div>
            <div class="flex items-center gap-2">
              <div class="rating rating-sm">
                <% 5.times { input_checked = false; %><input type="radio" name="r1" class="mask mask-star-2 bg-warning" checked disabled/><% } %>
              </div>
              <span class="text-xs text-base-content/40">(48)</span>
            </div>
            <div class="card-actions items-center justify-between">
              <p class="text-2xl font-black">€ 48<span class="text-sm font-normal text-base-content/40">,90</span></p>
              <div class="join">
                <button class="btn btn-ghost btn-sm join-item border border-base-300 rounded-l-xl tooltip" data-tip="Wishlist">♡</button>
                <button class="btn btn-primary btn-sm join-item rounded-r-xl px-5 text-[0.65rem] tracking-widest uppercase font-bold">Acquista</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# KIT 2 – featured %>
      <div class="tilt-card cursor-pointer lg:-translate-y-4" data-tilt>
        <div class="card bg-base-200 border-2 border-primary/50 overflow-hidden glow-pulse h-full"
             style="transform-style:preserve-3d;">
          <figure class="relative h-44 bg-gradient-to-br from-success/15 to-success/5">
            <div class="absolute inset-0 flex items-center justify-center text-8xl opacity-30">🌿</div>
            <div class="absolute top-4 left-4"><span class="badge badge-primary badge-sm font-bold">⭐ Più venduto</span></div>
            <div class="absolute top-4 right-4"><span class="badge badge-ghost badge-sm font-mono">KIT-02</span></div>
            <div class="absolute inset-0 bg-gradient-to-t from-base-200 via-transparent to-transparent"></div>
          </figure>
          <div class="card-body gap-4">
            <div style="transform:translateZ(18px);">
              <span class="badge badge-success badge-soft badge-xs mb-2 tracking-widest uppercase font-bold">Piante</span>
              <h2 class="card-title text-xl font-black">Kit "Foresta Sommersa"</h2>
              <p class="text-base-content/50 text-sm italic mt-1 leading-relaxed">"Nutri le piante dalle radici alle foglie. Effetto Nature Aquarium garantito."</p>
            </div>
            <div class="divider divider-success my-0 opacity-20"></div>
            <ul class="steps steps-vertical text-xs">
              <li class="step step-success" data-content="1"><span class="ml-2 text-xs text-base-content/70">Substrato fertile ad alto potere nutritivo</span></li>
              <li class="step step-success" data-content="2"><span class="ml-2 text-xs text-base-content/70">Fertilizzante liquido con ferro chelato</span></li>
              <li class="step step-success" data-content="3"><span class="ml-2 text-xs text-base-content/70">Pastiglie oligoelementi a lenta cessione</span></li>
            </ul>
            <div class="divider my-0 opacity-20"></div>
            <div class="flex items-center gap-2">
              <div class="rating rating-sm">
                <% 5.times { %><input type="radio" name="r2" class="mask mask-star-2 bg-warning" checked disabled/><% } %>
              </div>
              <span class="text-xs text-base-content/40">(73)</span>
            </div>
            <div class="card-actions items-center justify-between">
              <p class="text-2xl font-black">€ 67<span class="text-sm font-normal text-base-content/40">,50</span></p>
              <div class="join">
                <button class="btn btn-ghost btn-sm join-item border border-base-300 rounded-l-xl tooltip" data-tip="Wishlist">♡</button>
                <button class="btn btn-success btn-sm join-item rounded-r-xl px-5 text-[0.65rem] tracking-widest uppercase font-bold">Acquista</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# KIT 3 %>
      <div class="tilt-card cursor-pointer" data-tilt>
        <div class="card bg-base-200 border border-base-300 hover:border-secondary/40 overflow-hidden h-full"
             style="transform-style:preserve-3d;">
          <figure class="relative h-44 bg-gradient-to-br from-secondary/10 to-secondary/5">
            <div class="absolute inset-0 flex items-center justify-center text-8xl opacity-30">🧂</div>
            <div class="absolute top-4 left-4"><span class="badge badge-secondary badge-sm font-bold tracking-widest uppercase">Pro / Osmosi</span></div>
            <div class="absolute top-4 right-4"><span class="badge badge-ghost badge-sm font-mono">KIT-03</span></div>
            <div class="absolute inset-0 bg-gradient-to-t from-base-200 via-transparent to-transparent"></div>
          </figure>
          <div class="card-body gap-4">
            <div style="transform:translateZ(18px);">
              <h2 class="card-title text-xl font-black">Sali Professionali</h2>
              <p class="text-base-content/50 text-sm italic mt-1 leading-relaxed">"pH stabile 6.5–7.5. Indispensabili per i Discus più esigenti."</p>
            </div>
            <div class="divider divider-secondary my-0 opacity-20"></div>
            <ul class="steps steps-vertical text-xs">
              <li class="step step-secondary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">GH/KH bilanciati per Discus</span></li>
              <li class="step step-secondary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">Formula priva di sodio e cloro</span></li>
              <li class="step step-secondary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">pH stabile 6.5–7.5</span></li>
            </ul>
            <div class="divider my-0 opacity-20"></div>
            <div class="flex items-center gap-2">
              <div class="rating rating-sm">
                <% 5.times { %><input type="radio" name="r3" class="mask mask-star-2 bg-warning" checked disabled/><% } %>
              </div>
              <span class="text-xs text-base-content/40">(31)</span>
            </div>
            <div class="card-actions items-center justify-between">
              <p class="text-2xl font-black">€ 32<span class="text-sm font-normal text-base-content/40">,00</span></p>
              <div class="join">
                <button class="btn btn-ghost btn-sm join-item border border-base-300 rounded-l-xl tooltip" data-tip="Wishlist">♡</button>
                <button class="btn btn-secondary btn-sm join-item rounded-r-xl px-5 text-[0.65rem] tracking-widest uppercase font-bold">Acquista</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── CAROUSEL RECENSIONI ────────────────────────── %>
    <div class="mt-20">
      <div class="divider divider-primary opacity-30">
        <span class="text-[0.65rem] tracking-[0.3em] uppercase text-base-content/30 font-semibold">Cosa dicono i clienti</span>
      </div>
      <div class="carousel carousel-center gap-5 py-6 px-2 -mx-2">
        <% [
          { nome:"Marco T.", vasca:"200L planted", testo:"Il Kit Acqua Cristallina ha risolto i nitriti in 5 giorni.", img:"https://picsum.photos/seed/ma1/80/80" },
          { nome:"Alessia R.", vasca:"Discus 400L", testo:"Il pH non si muove di 0.1 in 30 giorni. Incredibile.", img:"https://picsum.photos/seed/al2/80/80" },
          { nome:"Luca B.", vasca:"Nature 120L", testo:"Prato di HC Cuba in 3 settimane con la Foresta Sommersa.", img:"https://picsum.photos/seed/lu3/80/80" },
          { nome:"Federica M.", vasca:"Malawi 300L", testo:"Sergio risponde in 10 minuti. Vale il doppio del prezzo.", img:"https://picsum.photos/seed/fe4/80/80" },
        ].each do |r| %>
          <div class="carousel-item">
            <div class="card bg-base-200 border border-base-300 w-80
                        hover:border-primary/30 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5
                        transition-all duration-300">
              <div class="card-body p-6 gap-3">
                <div class="flex items-center gap-3">
                  <div class="avatar"><div class="w-10 rounded-full"><img src="<%= r[:img] %>" alt="<%= r[:nome] %>"/></div></div>
                  <div>
                    <p class="font-bold text-sm"><%= r[:nome] %></p>
                    <p class="text-xs text-base-content/40"><%= r[:vasca] %></p>
                  </div>
                  <div class="ml-auto rating rating-xs">
                    <% 5.times { %><input type="radio" class="mask mask-star-2 bg-warning" checked disabled/><% } %>
                  </div>
                </div>
                <p class="text-sm text-base-content/60 italic leading-relaxed">"<%= r[:testo] %>"</p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── TRUST STATS ─────────────────────────────────── %>
    <div class="stats stats-vertical md:stats-horizontal bg-base-200 border border-base-300 rounded-3xl w-full mt-8 shadow">
      <% [
        { ico:"🔬", t:"Testato in vasca", d:"Non in laboratorio", v:"100%" },
        { ico:"🚚", t:"Spedito in 24h",   d:"Packaging protetto", v:"24h" },
        { ico:"💬", t:"SOS Sergio",        d:"Via WhatsApp", v:"10min" },
        { ico:"↩️", t:"Reso facile",       d:"Soddisfatti o rimborso", v:"30gg" },
      ].each do |s| %>
        <div class="stat place-items-center">
          <div class="stat-figure text-2xl"><%= s[:ico] %></div>
          <div class="stat-value text-primary text-xl"><%= s[:v] %></div>
          <div class="stat-title text-xs font-bold"><%= s[:t] %></div>
          <div class="stat-desc"><%= s[:d] %></div>
        </div>
      <% end %>
    </div>

    <%# ── FAQ ACCORDION ──────────────────────────────── %>
    <div class="mt-20 max-w-3xl mx-auto">
      <div class="divider divider-primary opacity-30 mb-8">
        <span class="text-[0.65rem] tracking-[0.3em] uppercase text-base-content/30 font-semibold">Domande frequenti</span>
      </div>
      <div class="space-y-2">
        <% [
          { q:"I kit sono adatti per qualsiasi dimensione?", a:"Sì. Ogni kit riporta le dosi per litro, calibrate da 30L a oltre 1000L." },
          { q:"Devo avere esperienza per usarli?", a:"Il Kit Startup è per principianti assoluti. Include istruzioni passo passo e accesso diretto a Sergio su WhatsApp." },
          { q:"Quanto durano i prodotti?", a:"Scadenza minima 24 mesi. Le fiale di batteri vivi vanno conservate in frigorifero dopo l'apertura." },
        ].each_with_index do |item, i| %>
          <div class="collapse collapse-arrow bg-base-200 border border-base-300 hover:border-primary/20 transition-colors rounded-2xl">
            <input type="radio" name="faq-shop" <%= i == 0 ? 'checked' : '' %>/>
            <div class="collapse-title font-semibold text-sm"><%= item[:q] %></div>
            <div class="collapse-content"><p class="text-sm text-base-content/60 leading-relaxed pt-1"><%= item[:a] %></p></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</div>

<script>
  document.querySelectorAll('[data-tilt]').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const rx = ((e.clientY - r.top  - r.height/2) / (r.height/2)) * -12;
      const ry = ((e.clientX - r.left - r.width /2) / (r.width /2)) *  12;
      card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.025,1.025,1.025)`;
      card.style.boxShadow = `${-ry*2}px ${rx*2}px 40px rgba(0,0,0,0.2)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(900px) rotateX(0) rotateY(0) scale3d(1,1,1)';
      card.style.boxShadow = '';
      card.style.transition = 'transform 0.5s ease, box-shadow 0.5s ease';
      setTimeout(() => { card.style.transition = ''; }, 500);
    });
  });
  const obs = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){ e.target.style.animationPlayState='running'; obs.unobserve(e.target);} }), {threshold:0.1});
  document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>
