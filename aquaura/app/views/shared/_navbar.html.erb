<%
  # ─── SINGLE SOURCE OF TRUTH per i link (fix #25, #29, #31) ──────────────────
  # Aggiungere/rimuovere link qui propaga automaticamente su mobile + desktop.
  # `desktop: false` esclude la voce dal menu orizzontale desktop.
  nav_links = [
    { label: "Home",         path: root_path,                  desktop: true  },
    { label: "Collezione",   path: galleria_path,              desktop: true  },
    { label: "Shop Online",  path: shop_path,                  desktop: true  },  # fix #25
    { label: "Servizi",      path: servizi_path,               desktop: true  },
    { label: "Journal",      path: blog_index_path,            desktop: true  },
    { label: "Contatti",     path: root_path(anchor: "contatti"), desktop: true, turbo_prefetch: false }  # fix #35
  ]

  # Helper: active? gestisce anche anchor e route annidate (fix #27)
  # Valuta sia current_page? che controller/action match
  def nav_active?(path)
    current_page?(path) rescue false
  end
%>

<%# ─── Scroll Progress Indicator ──────────────────────────────────────────── %>
<%# will-change aggiunto inline come attributo data (gestito dal controller) (fix #23) %>
<div
  data-controller="navbar"
  class="relative"
  data-navbar-reduced-motion-value="<%= request.headers['Sec-CH-Prefers-Reduced-Motion'] == 'reduce' %>"
>
  <%# Barra progresso scroll (fix #23 will-change gestito via JS) %>
  <div
    data-navbar-target="progress"
    aria-hidden="true"
    class="fixed top-0 left-0 h-[2px] bg-primary z-[2000] scale-x-0 origin-left"
    style="transition: transform 0.2s linear; will-change: transform;"
  ></div>

  <%# ─── Mobile Menu: usa <dialog> nativo al posto del checkbox hack ─────────
      Fix #1 (checkbox hack), #5 (focus trap nativo), #7 (aria-label) ──────── %>
  <dialog
    data-navbar-target="mobileDialog"
    id="mobile-nav-dialog"
    aria-label="Menu navigazione mobile"
    class="modal lg:hidden bg-transparent p-0 max-w-none w-full h-dvh z-[9999]"
  >
    <div
      class="modal-box max-w-none w-full h-full rounded-none border-0 px-8 pt-10 pb-12
             bg-[#050505] flex flex-col justify-between overflow-hidden relative"
    >
      <%# Grain Texture Overlay %>
      <div class="menu-grain-overlay absolute inset-0 z-0"></div>
      <%# Mobile Header %>
      <div class="flex items-center justify-between">
        <%= link_to root_path,
            class: "font-serif text-[1.4rem] tracking-[.18em] uppercase text-white no-underline",
            aria: { label: "Aquaura – torna alla home" } do %>
          Aquaura<span class="text-primary" aria-hidden="true">.</span>
        <% end %>

        <%# Chiudi menu — fix #7 (aria-label esplicita) fix #14 (focus return) %>
        <button
          data-action="click->navbar#closeMobileMenu"
          class="btn btn-ghost btn-circle border border-white/5 text-white/40 hover:text-white transition-all duration-500"
          aria-label="Chiudi menu"
          type="button"
        >
          <div class="burger-icon is-open">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>
      </div>

      <%# ── Mobile Nav Links ──────────────────────────────────────────────────
          Fix #22: transition-delay gestito con CSS nth-child, non inline style
          Fix #29: stessa lista `nav_links` del desktop ─────────────────────── %>
      <nav class="flex-1 flex flex-col items-start justify-center relative z-10" aria-label="Menu principale">
        <ul class="w-full space-y-8">
          <% nav_links.each do |item| %>
            <li class="mob-nav-item flex items-center group">
              <% is_active = nav_active?(item[:path]) %>
              <% if is_active %>
                <div class="nav-link-active-dot"></div>
              <% end %>
              
              <%= link_to item[:label], item[:path],
                  class: "font-serif text-[2.4rem] font-light tracking-tight transition-all duration-700 nav-link-magical
                         #{is_active ? 'text-primary' : 'text-white/40 hover:text-white translate-x-0 hover:translate-x-2'}",
                  aria: { current: (is_active ? "page" : false) },
                  data: (item[:turbo_prefetch] == false ? { turbo_prefetch: "false" } : {}) %>
            </li>
          <% end %>
        </ul>
      </nav>

      <%# Mobile Footer: Info & CTA %>
      <div class="pb-6 flex flex-col gap-10 mob-nav-footer relative z-10">
        <div class="flex items-center gap-4 text-[10px] uppercase tracking-[0.4em] text-white/20 font-mono">
          <span>Studio · Roma</span>
          <span class="w-1 h-1 rounded-full bg-white/10"></span>
          <span>@aquaura.art</span>
          <span class="w-1 h-1 rounded-full bg-white/10"></span>
          <span>hello@aquaura.com</span>
        </div>

        <%= link_to root_path(anchor: "contatti"),
            class: "cta-magic-border group flex items-center justify-between w-full rounded-full py-5 px-8 text-white no-underline transition-all duration-500",
            data: { action: "click->navbar#closeMobileMenu" } do %>
          <span class="text-[0.9rem] uppercase tracking-[0.3em] font-light">Inizia Progetto</span>
          <svg class="w-5 h-5 translate-x-0 group-hover:translate-x-2 transition-transform duration-500" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.16669 10H15.8334M15.8334 10L10.8334 5M15.8334 10L10.8334 15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% end %>
      </div>
    </div>

    <%# Backdrop click per chiudere (fix #1 — comportamento dialog nativo) %>
    <form method="dialog" class="modal-backdrop">
      <button type="submit" aria-label="Chiudi menu">close</button>
    </form>
  </dialog>

  <%# ─── Desktop Navbar (Fixed on scroll) ────────────────────────────────── %>
  <div class="fixed top-0 inset-x-0 z-[1002] px-4 md:px-8 pointer-events-none">
    <div
      data-navbar-target="bar"
      class="navbar mx-auto w-full max-w-[--navbar-max-w] mt-4 md:mt-6 rounded-2xl pointer-events-auto
             bg-white/5 backdrop-blur-xl border border-white/10
             shadow-[0_20px_60px_rgba(0,0,0,0.45)]
             transition-[max-width,margin,background,box-shadow] duration-700 ease-out"
      style="--navbar-max-w: 1400px;"
    >
      <%# ── Logo ─────────────────────────────────────────────────────────── %>
      <div class="navbar-start gap-3">
        <%# Burger: fix #2 (aria-expanded), fix #4 implicitamente con label %>
        <button
          data-action="click->navbar#openMobileMenu"
          data-navbar-target="burger"
          class="btn btn-ghost btn-circle text-white/70 hover:text-white lg:hidden group"
          aria-label="Apri menu di navigazione"
          aria-expanded="false"
          aria-controls="mobile-nav-dialog"
          type="button"
        >
          <div class="burger-icon">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </button>

        <%= link_to root_path,
            class: "font-serif text-[1.3rem] font-medium tracking-[.16em] uppercase
                    text-white hover:scale-[1.02] transition-transform no-underline pl-2",
            aria: { label: "Aquaura – Home" } do %>
          Aquaura<span class="text-primary" aria-hidden="true">.</span>
        <% end %>
      </div>

      <%# ── Desktop Menu ──────────────────────────────────────────────────── %>
      <%# Fix #6: nav con aria-label esplicito ────────────────────────────── %>
      <nav class="navbar-center hidden lg:flex" aria-label="Navigazione principale">
        <ul class="menu menu-horizontal gap-1.5 p-0" role="list">
          <% nav_links.select { |i| i[:desktop] }.each do |item| %>
            <li role="listitem">
              <% class_list = "relative px-5 py-2.5 text-[0.8rem] uppercase font-light tracking-[.25em] transition-all duration-300 rounded-xl" %>
              <% active_class = nav_active?(item[:path]) ? 'text-white bg-white/10 border-b-2 border-primary/60' : 'text-white/50 hover:text-white hover:bg-white/5' %>
              <%= link_to item[:label], item[:path],
                  class: "#{class_list} #{active_class}",
                  aria: { current: (nav_active?(item[:path]) ? "page" : false) },
                  data: (item[:turbo_prefetch] == false ? { turbo_prefetch: "false" } : {}) %>
            </li>
          <% end %>
        </ul>
      </nav>

      <%# ── Right Actions ─────────────────────────────────────────────────── %>
      <div class="navbar-end gap-3 pr-2">
        <%# Search: fix #4 (aria-label) e fix #28 (collegato a Stimulus) %>
        <button
          data-action="click->navbar#openSearch"
          class="btn btn-ghost btn-circle text-white/30 hover:text-white transition-colors"
          aria-label="Cerca nel sito"
          aria-haspopup="dialog"
          type="button"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <%# Fix #26: CTA sempre visibile (rimosso hidden sm:inline-flex) %>
        <%= link_to "Inizia Progetto", root_path(anchor: "contatti"),
            class: "btn btn-primary btn-sm rounded-full px-6 text-[0.75rem] uppercase tracking-[.2em]
                    border-0 hover:scale-[1.05] transition-all duration-300 inline-flex h-10
                    hover:shadow-[0_12px_30px_color-mix(in_oklch,var(--color-primary)_30%,transparent)]" %>
      </div>
    </div>
  </div>

</div>
