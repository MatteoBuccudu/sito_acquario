<input type="checkbox" id="nav-mobile-menu" class="modal-toggle lg:hidden" />

<!-- Fullscreen mobile popup menu -->
<div class="modal lg:hidden" role="dialog" aria-label="Mobile navigation">
  <div class="modal-box max-w-none w-full h-full rounded-none border-0 px-6 sm:px-8 pt-7 pb-10
              bg-[#020617]/98 backdrop-blur-3xl flex flex-col">
    <div class="flex items-center justify-between">
      <%= link_to root_path,
          class: "font-serif text-[1.3rem] font-medium tracking-[.18em] uppercase text-[#f5f3ec] hover:text-white transition-colors no-underline" do %>
        Aquaura<span class="text-primary">.</span>
      <% end %>
      <label for="nav-mobile-menu"
        class="btn btn-ghost btn-circle border border-white/10 text-white/70 hover:text-white hover:bg-white/10 hover:border-white/40">
        <span class="sr-only">Chiudi menu</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6L6 18" />
          <path d="M6 6l12 12" />
        </svg>
      </label>
    </div>

    <% mobile_link_base = "block w-full text-center text-[1.4rem] sm:text-[1.55rem] font-light tracking-[.06em] text-white/80 hover:text-white transition-colors duration-200" %>
    <% mobile_link_active = "bg-primary/90 text-[#050816] shadow-[0_12px_40px_rgba(15,23,42,0.9)]" %>

    <nav class="mt-14 flex-1 flex flex-col items-center justify-start">
      <ul class="w-full max-w-sm space-y-1.5">
        <li>
          <%= link_to "Home", root_path,
              class: [
                mobile_link_base,
                (current_page?(root_path) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Collezione", galleria_path,
              class: [
                mobile_link_base,
                (current_page?(galleria_path) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Shop Online", shop_path,
              class: [
                mobile_link_base,
                (current_page?(shop_path) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Servizi", servizi_path,
              class: [
                mobile_link_base,
                (current_page?(servizi_path) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Journal", blog_index_path,
              class: [
                mobile_link_base,
                (current_page?(blog_index_path) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Contatti", root_path(anchor: "contatti"),
              class: [
                mobile_link_base,
                (current_page?(root_path(anchor: "contatti")) ? mobile_link_active : "hover:bg-white/5")
              ].compact.join(" ") %>
        </li>
      </ul>
    </nav>

    <div class="mt-10 flex justify-center">
      <%= link_to "Inizia Progetto", root_path,
          class: "btn btn-primary btn-wide rounded-full text-[0.8rem] tracking-[.18em] uppercase border-0" %>
    </div>
  </div>
</div>

<!-- Desktop / main navbar -->
<div class="fixed top-0 inset-x-0 z-[1002] px-4 md:px-6">
  <div
    class="navbar mx-auto w-full max-w-[1400px] mt-3 md:mt-4 rounded-2xl
           bg-white/8 backdrop-blur-2xl
           border border-white/15
           shadow-[0_18px_60px_rgba(0,0,0,0.7)]">

    <% base_nav_link = "relative text-[0.82rem] uppercase tracking-[.2em] font-light px-4 py-2 rounded-xl border-b border-transparent text-base-content/60 hover:text-white hover:border-white/40 hover:bg-white/5 transition-colors duration-300" %>

    <!-- Logo + mobile trigger -->
    <div class="navbar-start gap-2">
      <!-- Mobile open button -->
      <label
        for="nav-mobile-menu"
        class="btn btn-ghost btn-circle text-base-content/70 hover:text-white lg:hidden"
        aria-label="Apri navigazione">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>

      <!-- Logo -->
      <%= link_to root_path,
          class: "font-serif text-[1.25rem] md:text-[1.35rem] font-medium tracking-[.16em] uppercase text-[#f5f3ec] hover:text-white transition-colors no-underline" do %>
        Aquaura<span class="text-primary">.</span>
      <% end %>
    </div>

    <!-- Desktop links -->
    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 gap-1">
        <li>
          <%= link_to "Home", root_path,
              class: [
                base_nav_link,
                (current_page?(root_path) ? "text-white border-white/70" : nil)
              ].compact.join(" ") %>
        </li>
        <li>
          <details>
            <summary class="relative text-[0.82rem] uppercase tracking-[.2em] font-light px-4 py-2 rounded-xl
                           border-b border-transparent text-base-content/60 hover:text-white hover:border-white/40 hover:bg-white/5 transition-colors duration-300">
              Collezione
            </summary>
            <ul
              class="bg-base-100/95 backdrop-blur-2xl rounded-2xl mt-2 p-2 shadow-2xl border border-white/10 w-60">
              <li>
                <%= link_to shop_path,
                    class: "flex items-center gap-2.5 rounded-xl px-3 py-2 hover:bg-primary/10 transition-colors" do %>
                  <span class="w-7 h-7 shrink-0 rounded-lg bg-primary/15 flex items-center justify-center text-xs">✦</span>
                  <div>
                    <p class="text-[0.85rem] text-[#f5f3ec] font-medium">Shop Online</p>
                    <p class="text-[0.75rem] text-base-content/60">Creature &amp; accessori</p>
                  </div>
                <% end %>
              </li>
              <li>
                <%= link_to galleria_path,
                    class: "flex items-center gap-2.5 rounded-xl px-3 py-2 hover:bg-primary/10 transition-colors" do %>
                  <span class="w-7 h-7 shrink-0 rounded-lg bg-primary/15 flex items-center justify-center text-xs">◈</span>
                  <div>
                    <p class="text-[0.85rem] text-[#f5f3ec] font-medium">Showcase</p>
                    <p class="text-[0.75rem] text-base-content/60">Le nostre installazioni</p>
                  </div>
                <% end %>
              </li>
            </ul>
          </details>
        </li>
        <li>
          <%= link_to "Servizi", servizi_path,
              class: [
                base_nav_link,
                (current_page?(servizi_path) ? "text-white border-white/70" : nil)
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Journal", blog_index_path,
              class: [
                base_nav_link,
                (current_page?(blog_index_path) ? "text-white border-white/70" : nil)
              ].compact.join(" ") %>
        </li>
        <li>
          <%= link_to "Contatti", root_path(anchor: "contatti"),
              class: [
                base_nav_link,
                (current_page?(root_path(anchor: "contatti")) ? "text-white border-white/70" : nil)
              ].compact.join(" ") %>
        </li>
      </ul>
    </div>

    <!-- Right side -->
    <div class="navbar-end gap-2">
      <button
        class="btn btn-ghost btn-circle hidden md:inline-flex text-base-content/60 hover:text-white hover:bg-white/5"
        aria-label="Cerca">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <circle cx="11" cy="11" r="7" />
          <path d="m21 21-4.35-4.35" />
        </svg>
      </button>

      <%= link_to "Inizia Progetto", root_path,
          class: "btn btn-primary btn-sm rounded-full px-5 text-[0.78rem] uppercase tracking-[.16em] border-0
                  hover:-translate-y-0.5 hover:shadow-[0_10px_30px_oklch(68%_0.22_38_/_0.55)]
                  transition-transform transition-shadow duration-300 hidden sm:inline-flex" %>
    </div>
  </div>
</div>
