<style>
  /* Animazione onda decorativa */
  @keyframes wave-drift {
    0%, 100% { transform: translateX(0) scaleY(1); }
    50%       { transform: translateX(-2%) scaleY(0.96); }
  }
  .wave-bg { animation: wave-drift 8s ease-in-out infinite; }

  @keyframes bubble-rise {
    0%   { transform: translateY(0) scale(1);   opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(-120px) scale(1.4); opacity: 0; }
  }
  .bubble { animation: bubble-rise linear infinite; }
</style>

<footer class="relative overflow-hidden bg-base-200 border-t border-primary/10 transition-colors duration-500">

  <% # ── Sfondo gradiente acqua profonda ── %>
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    <div class="absolute -top-[200px] left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full bg-[radial-gradient(ellipse,var(--color-primary)_0%,transparent_70%)] opacity-5"></div>
    <div class="absolute bottom-0 left-[20%] w-[300px] h-[300px] rounded-full bg-[radial-gradient(circle,var(--color-accent)_0%,transparent_70%)] opacity-5"></div>
    
    <% # Bolle decorative %>
    <% [
         { left: "15%", size: "5px", delay: "0s", dur: "7s" },
         { left: "28%", size: "3px", delay: "1.5s", dur: "9s" },
         { left: "42%", size: "7px", delay: "3s", dur: "11s" },
         { left: "61%", size: "4px", delay: "0.8s", dur: "8s" },
         { left: "75%", size: "6px", delay: "2.2s", dur: "10s" },
         { left: "88%", size: "3px", delay: "4s", dur: "7.5s" },
       ].each do |b| %>
      <div class="bubble absolute bottom-[40px] rounded-full bg-primary/30" 
           style="left:<%= b[:left] %>; width:<%= b[:size] %>; height:<%= b[:size] %>; animation-duration:<%= b[:dur] %>; animation-delay:<%= b[:delay] %>;"></div>
    <% end %>
  </div>

  <% # ══════════════════════════════════════════════════════════════════════ %>
  <% # 1. HERO CTA ── icona + headline + button %>
  <% # ══════════════════════════════════════════════════════════════════════ %>
  <div class="relative z-10 text-center px-6 pt-20 pb-16">

    <% # Icona acquario %>
    <div class="inline-flex items-center justify-center w-[72px] h-[72px] rounded-[20px] mb-7
                bg-gradient-to-br from-primary/10 to-accent/5
                border border-primary/20
                shadow-[0_0_30px_color-mix(in_srgb,var(--color-primary)_12%,transparent)]">
      <svg width="36" height="36" fill="none" stroke="currentColor" class="text-primary opacity-90" stroke-width="1.4" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 3C7 3 3 7 3 12s4 9 9 9 9-4 9-9-4-9-9-9z
                 M3 12h18
                 M12 3c-2.5 3-4 5.5-4 9s1.5 6 4 9
                 M12 3c2.5 3 4 5.5 4 9s-1.5 6-4 9"/>
      </svg>
    </div>

    <h2 class="text-[clamp(1.8rem,5vw,3rem)] font-bold tracking-tight text-base-content mb-4 leading-tight">
      Porta l'oceano a casa tua
    </h2>
    <p class="text-[0.95rem] text-base-content/60 max-w-[420px] mx-auto mb-8 leading-relaxed">
      Ecosistemi acquatici su misura, progettati con cura artigianale per ambienti residenziali e commerciali di lusso.
    </p>

    <%= link_to root_path(anchor: "contatti"),
                class: "group inline-flex items-center gap-2.5 px-8 py-3.5 rounded-xl
                        bg-primary hover:bg-primary-focus
                        text-primary-content font-bold text-[0.85rem] tracking-[0.04em]
                        shadow-[0_0_30px_color-mix(in_srgb,var(--color-primary)_30%,transparent)]
                        hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-primary)_50%,transparent)]
                        hover:-translate-y-px transition-all duration-200" do %>
      Inizia il tuo progetto
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    <% end %>
  </div>

  <% # ══════════════════════════════════════════════════════════════════════ %>
  <% # 2. LINK GRID — 4 colonne stile screenshot %>
  <% # ══════════════════════════════════════════════════════════════════════ %>
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 pb-16 grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-12">

    <% # Colonna 1 — Esplora %>
    <div>
      <p class="text-[0.65rem] tracking-[0.25em] text-base-content/40 font-semibold uppercase mb-6">
        // &nbsp;Esplora
      </p>
      <ul class="flex flex-col gap-4">
        <% [
             { label: "Shop Online", path: shop_path },
             { label: "Showcase", path: galleria_path },
             { label: "Journal", path: blog_index_path },
             { label: "Collezione", path: galleria_path },
           ].each do |item| %>
          <li>
            <%= link_to item[:label], item[:path],
                        class: "text-[0.9rem] text-base-content/60 hover:text-base-content transition-colors duration-150 tracking-[0.01em]" %>
          </li>
        <% end %>
      </ul>
    </div>

    <% # Colonna 2 — Servizi %>
    <div>
      <p class="text-[0.65rem] tracking-[0.25em] text-base-content/40 font-semibold uppercase mb-6">
        // &nbsp;Servizi
      </p>
      <ul class="flex flex-col gap-4">
        <% [
             { label: "Landscape Design", path: servizi_path },
             { label: "Medical Checkup", path: servizi_path },
             { label: "Manutenzione H24", path: servizi_path },
             { label: "Consulenza", path: servizi_path },
           ].each do |item| %>
          <li>
            <%= link_to item[:label], item[:path],
                        class: "text-[0.9rem] text-base-content/60 hover:text-base-content transition-colors duration-150 tracking-[0.01em]" %>
          </li>
        <% end %>
      </ul>
    </div>

    <% # Colonna 3 — Risorse %>
    <div>
      <p class="text-[0.65rem] tracking-[0.25em] text-base-content/40 font-semibold uppercase mb-6">
        // &nbsp;Risorse
      </p>
      <ul class="flex flex-col gap-4">
        <% [
             { label: "Come Funziona", path: servizi_path },
             { label: "Galleria Lavori", path: galleria_path },
             { label: "Blog & Consigli", path: blog_index_path },
             { label: "FAQ", path: root_path },
           ].each do |item| %>
          <li>
            <%= link_to item[:label], item[:path],
                        class: "text-[0.9rem] text-base-content/60 hover:text-base-content transition-colors duration-150 tracking-[0.01em]" %>
          </li>
        <% end %>
      </ul>
    </div>

    <% # Colonna 4 — Supporto %>
    <div>
      <p class="text-[0.65rem] tracking-[0.25em] text-base-content/40 font-semibold uppercase mb-6">
        // &nbsp;Supporto
      </p>
      <ul class="flex flex-col gap-4">
        <% [
             { label: "Dashboard Clienti", path: dashboard_path },
             { label: "Area Contatti", path: root_path(anchor: "contatti") },
             { label: "Preventivo", path: root_path(anchor: "contatti") },
             { label: "Emergenze", path: root_path(anchor: "contatti") },
           ].each do |item| %>
          <li>
            <%= link_to item[:label], item[:path],
                        class: "text-[0.9rem] text-base-content/60 hover:text-base-content transition-colors duration-150 tracking-[0.01em]" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <% # Divider %>
  <div class="relative z-10 max-w-[1200px] mx-auto px-6">
    <div class="h-px bg-base-content/10 transition-colors duration-500"></div>
  </div>

  <% # ══════════════════════════════════════════════════════════════════════ %>
  <% # 3. NEWSLETTER %>
  <% # ══════════════════════════════════════════════════════════════════════ %>
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-8">

    <div class="max-w-[420px] text-center md:text-left">
      <h3 class="text-[1.1rem] font-bold tracking-tight text-base-content mb-2">
        Non perdere i nostri aggiornamenti
      </h3>
      <p class="text-[0.85rem] text-base-content/60 leading-relaxed">
        Consigli sulla cura degli acquari, nuovi arrivi e storie dal mondo sommerso.
        Massimo una email al mese.
      </p>
    </div>

    <div class="flex flex-col gap-3 w-full md:w-auto min-w-[280px]">
      <div class="flex flex-col sm:flex-row gap-2">
        <input
          type="email"
          placeholder="esempio@email.com"
          class="flex-1 px-4 py-3 rounded-xl
                 bg-base-100
                 border border-base-content/10
                 text-base-content text-[0.875rem] outline-none
                 focus:border-primary focus:ring-1 focus:ring-primary
                 transition-all placeholder-base-content/30"
        />
        <button
          class="btn btn-primary px-5 py-3 rounded-xl font-bold text-[0.8rem] tracking-[0.05em] whitespace-nowrap shadow-sm hover:-translate-y-px active:scale-95 transition-all"
        >
          Iscriviti
        </button>
      </div>
      <p class="text-[0.7rem] text-base-content/40 tracking-[0.02em] text-center md:text-left">
        Nessuno spam. Cancellati in qualsiasi momento.
      </p>
    </div>
  </div>

  <% # ══════════════════════════════════════════════════════════════════════ %>
  <% # 4. BOTTOM BAR %>
  <% # ══════════════════════════════════════════════════════════════════════ %>
  <div class="relative z-10 max-w-[1200px] mx-auto px-6">
    <div class="h-px bg-base-content/10 transition-colors duration-500"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 py-6 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">

    <p class="text-[0.75rem] text-base-content/40 tracking-[0.03em]">
      © <%= Time.now.year %> Aquaura Luxury Systems. Tutti i diritti riservati.
    </p>

    <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 text-[0.75rem]">
      <%= link_to "Privacy Policy", root_path, class: "text-base-content/50 hover:text-base-content transition-colors tracking-[0.03em]" %>
      <%= link_to "Termini di Servizio", root_path, class: "text-base-content/50 hover:text-base-content transition-colors tracking-[0.03em]" %>

      <% # Social icons %>
      <div class="flex gap-3 justify-center">
        <a href="#" class="flex items-center justify-center w-8 h-8 rounded-lg
                           bg-base-100 border border-base-content/10
                           text-base-content/50
                           hover:bg-primary/10 hover:border-primary/30 hover:text-primary
                           transition-all">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
          </svg>
        </a>
        <a href="#" class="flex items-center justify-center w-8 h-8 rounded-lg
                           bg-base-100 border border-base-content/10
                           text-base-content/50
                           hover:bg-primary/10 hover:border-primary/30 hover:text-primary
                           transition-all">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

</footer>