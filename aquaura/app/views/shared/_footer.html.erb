<footer class="mt-20 border-t border-white/5/! bg-gradient-to-b from-transparent via-[#050712]/80 to-[#020308] text-sm text-base-content/70">
  <div class="mx-auto w-full max-w-[1400px] px-4 md:px-8 lg:px-10 py-10 md:py-14">
    <div class="flex flex-col md:flex-row gap-10 md:gap-14 lg:gap-20">

      <!-- Brand / about -->
      <div class="md:w-[32%] space-y-4">
        <div class="inline-flex items-center gap-2">
          <span class="font-serif text-[1.4rem] font-medium tracking-[.08em] text-[#f5f3ec]">
            Aquaura<span class="text-primary">.</span>
          </span>
        </div>
        <p class="text-[0.86rem] leading-relaxed text-base-content/70">
          Acquari su misura, ecosistemi acquatici curati scientificamente e design luminoso per case, uffici e spazi commerciali.
        </p>
        <div class="flex items-center gap-3 pt-1">
          <span class="badge badge-outline badge-sm border-white/15 text-[0.72rem] tracking-[.16em] uppercase rounded-full px-3">
            Dottore dell'acqua
          </span>
          <span class="text-[0.78rem] text-base-content/50">
            Dal 2012 in Italia
          </span>
        </div>
      </div>

      <!-- Quick nav -->
      <div class="md:flex-1 grid grid-cols-2 sm:grid-cols-3 gap-8 md:gap-10">
        <div>
          <h3 class="text-[0.78rem] uppercase tracking-[.22em] text-base-content/50 mb-4">
            Navigazione
          </h3>
          <ul class="space-y-2.5 text-[0.86rem]">
            <li><%= link_to "Home", root_path, class: "link-hover text-base-content/75 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Collezione", galleria_path, class: "link-hover text-base-content/75 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Servizi", servizi_path, class: "link-hover text-base-content/75 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Journal", blog_index_path, class: "link-hover text-base-content/75 hover:text-primary transition-colors" %></li>
            <li><%= link_to "Contatti", root_path, class: "link-hover text-base-content/75 hover:text-primary transition-colors" %></li>
          </ul>
        </div>

        <div>
          <h3 class="text-[0.78rem] uppercase tracking-[.22em] text-base-content/50 mb-4">
            Servizi
          </h3>
          <ul class="space-y-2.5 text-[0.86rem]">
            <li><span class="text-base-content/75">Progettazione acquari su misura</span></li>
            <li><span class="text-base-content/75">Manutenzione programmata</span></li>
            <li><span class="text-base-content/75">Consulenza biologica</span></li>
            <li><span class="text-base-content/75">Installazioni per business</span></li>
          </ul>
        </div>

        <!-- Newsletter / contact -->
        <div class="sm:col-span-1 col-span-2 space-y-3">
          <h3 class="text-[0.78rem] uppercase tracking-[.22em] text-base-content/50 mb-1">
            Rimani in superficie
          </h3>
          <p class="text-[0.84rem] text-base-content/65">
            Novità, progetti unici e consigli di cura direttamente nella tua inbox.
          </p>
          <form class="mt-3 flex flex-col sm:flex-row gap-3 max-w-md">
            <input
              type="email"
              placeholder="La tua email"
              class="input input-sm w-full rounded-xl bg-white/5 border-white/10 placeholder:text-base-content/40 focus:border-primary focus:outline-none"
            >
            <button type="submit" class="btn btn-primary btn-sm rounded-xl px-5 tracking-[.12em] uppercase text-[0.75rem]">
              Iscriviti
            </button>
          </form>
          <div class="flex items-center gap-3 pt-2">
            <a href="#" class="btn btn-ghost btn-xs rounded-full min-h-0 h-8 w-8 px-0 border border-white/10 hover:border-primary/60 hover:bg-primary/10">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22 5.92a8.38 8.38 0 0 1-2.36.65A4.07 4.07 0 0 0 21.4 4a8.19 8.19 0 0 1-2.6 1A4.11 4.11 0 0 0 12 7.86a11.65 11.65 0 0 1-8.45-4.29A4.06 4.06 0 0 0 4.7 9.5a4.09 4.09 0 0 1-1.86-.5v.05A4.12 4.12 0 0 0 6.1 13a4.09 4.09 0 0 1-1.85.07A4.12 4.12 0 0 0 7.9 15.7 8.24 8.24 0 0 1 2 17.54 11.62 11.62 0 0 0 8.29 19.4 11.61 11.61 0 0 0 20 7.7c0-.18 0-.35-.01-.53A8.18 8.18 0 0 0 22 5.92Z"/>
              </svg>
            </a>
            <a href="#" class="btn btn-ghost btn-xs rounded-full min-h-0 h-8 w-8 px-0 border border-white/10 hover:border-primary/60 hover:bg-primary/10">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.04c-5.5 0-9.96 4.46-9.96 9.96 0 4.41 3.6 8.07 8.29 8.87v-6.28H8.1v-2.59h2.23V9.41c0-2.2 1.3-3.41 3.3-3.41.96 0 1.96.17 1.96.17v2.16h-1.1c-1.08 0-1.42.67-1.42 1.35v1.63h2.42l-.39 2.59h-2.03v6.28c4.69-.8 8.29-4.46 8.29-8.87 0-5.5-4.46-9.96-9.96-9.96Z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom line -->
      <div class="mt-10 pt-6 soft-divider"></div>
      <div class="mt-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-[0.78rem] text-base-content/50">
        <p>© <%= Time.current.year %> Aquaura. Tutti i diritti riservati.</p>
        <div class="flex flex-wrap gap-4">
          <a href="#" class="hover:text-primary transition-colors">Privacy</a>
          <a href="#" class="hover:text-primary transition-colors">Cookie</a>
          <span class="text-base-content/40">Realizzato con Ruby on Rails &amp; DaisyUI</span>
        </div>
      </div>
    </div>
  </div>
</footer>

