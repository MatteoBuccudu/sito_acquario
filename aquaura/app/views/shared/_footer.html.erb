<footer class="relative z-30 overflow-hidden bg-base-200 border-t border-base-content/10 pt-20 pb-10 backdrop-blur-3xl">
  <!-- Decorative Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>
  
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-24 mb-16">
    <!-- Branding Section -->
    <div class="space-y-8">
      <%= link_to root_path, class: "group inline-flex items-center gap-3 transition-transform duration-500 hover:scale-105" do %>
        <div class="p-3 bg-primary/10 rounded-2xl border border-primary/20 shadow-[0_0_20px_color-mix(in srgb, var(--p) 10%, transparent)] group-hover:shadow-[0_0_30px_color-mix(in srgb, var(--p) 20%, transparent)] transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25 1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75l-2.25-1.313M12 21.75V19.5" />
          </svg>
        </div>
        <span class="font-serif text-3xl font-medium tracking-tighter text-base-content">Aquaura<span class="text-primary">.</span></span>
      <% end %>

      <p class="text-base-content/60 font-light leading-relaxed max-w-xs text-sm italic">
        "Creiamo ecosistemi acquatici che sfidano la gravità, portando il lusso sommerso nel cuore della tua casa."
      </p>

      <!-- Social Links -->
      <div class="flex items-center gap-4">
        <a href="#" class="p-2 bg-base-content/5 rounded-full border border-base-content/10 text-base-content/60 hover:text-primary hover:border-primary/50 hover:bg-primary/5 transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"></path></svg>
        </a>
        <a href="#" class="p-2 bg-base-content/5 rounded-full border border-base-content/10 text-base-content/60 hover:text-primary hover:border-primary/50 hover:bg-primary/5 transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"></path></svg>
        </a>
      </div>
    </div>

    <!-- Links Section 1 -->
    <div>
      <h6 class="font-serif text-base-content text-lg font-medium tracking-wide mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
        </svg>
        Esplora
      </h6>
      <ul class="space-y-4">
        <li>
          <%= link_to shop_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            Shop Online
          <% end %>
        </li>
        <li>
          <%= link_to galleria_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            Showcase
          <% end %>
        </li>
        <li>
          <%= link_to blog_index_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18c-2.305 0-4.408.867-6 2.292m0-14.25v14.25" />
            </svg>
            Journal
          <% end %>
        </li>
      </ul>
    </div>

    <!-- Links Section 2 -->
    <div>
      <h6 class="font-serif text-base-content text-lg font-medium tracking-wide mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.423 20.242L21 10.666a2.121 2.121 0 000-3L16.334 3l-9.577 9.577a2.12 2.12 0 00-.591 1.05l-1.009 4.304c-.103.44.316.83.743.702l4.304-1.217a2.25 2.25 0 001.22-.874z" />
        </svg>
        Servizi
      </h6>
      <ul class="space-y-4">
        <li>
          <%= link_to servizi_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37a2.121 2.121 0 013 3l-9.37 9.37a2.121 2.121 0 01-3 0l-9.37-9.37a2.121 2.121 0 013-3l9.37 9.37z" />
            </svg>
            Landscape Design
          <% end %>
        </li>
        <li>
          <%= link_to servizi_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
            Medical Checkup
          <% end %>
        </li>
        <li>
          <%= link_to servizi_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary/50 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Manutenzione H24
          <% end %>
        </li>
      </ul>
    </div>

    <!-- Legal Section -->
    <div>
      <h6 class="font-serif text-base-content text-lg font-medium tracking-wide mb-6 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0a.75.75 0 01-.75-.75V3.75a.75.75 0 011.5 0v15.75a.75.75 0 01-.75.75zm0 0l-3-3m3 3l3-3" />
        </svg>
        Supporto
      </h6>
      <ul class="space-y-4">
        <li>
          <%= link_to dashboard_path, class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            Dashboard Clienti
          <% end %>
        </li>
        <li>
          <%= link_to root_path(anchor: "contatti"), class: "group flex items-center gap-2 text-base-content/60 hover:text-base-content transition-colors text-sm font-light" do %>
            Area Contatti
          <% end %>
        </li>
        <li class="pt-4 border-t border-base-content/10 opacity-40 text-[10px] uppercase tracking-[0.2em]">
          © <%= Time.now.year %> Aquaura Luxury Systems.
        </li>
      </ul>
    </div>
  </div>
</footer>

