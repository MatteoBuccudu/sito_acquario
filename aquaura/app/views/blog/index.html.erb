<%# ══════════════════════════════════════════════════════
    Journal — Pillole di Saggezza
    Layout 1:1 dal reference screenshot:
      1. Hero split (testo + stat row + immagine destra)
      2. "Scriviamo di…" — testo sx + 3 dark feature card dx
      3. Catalogo articoli — scroll orizzontale + nav
      4. Come seguirci — 4 card orizzontali
      5. Tre passi — numbered col layout
    Stack: DaisyUI 5 · Tailwind CSS · CSS puro
══════════════════════════════════════════════════════ %>

<style>
  /* ─── Animazioni ─────────────────────────────────── */
  @keyframes fade-up {
    from { opacity:0; transform:translateY(20px); }
    to   { opacity:1; transform:translateY(0);    }
  }
  @keyframes fade-in-right {
    from { opacity:0; transform:translateX(28px); }
    to   { opacity:1; transform:translateX(0);    }
  }
  .anim { opacity:0; animation-duration:.65s; animation-fill-mode:both;
          animation-timing-function:cubic-bezier(.22,.68,0,1.2);
          animation-play-state:paused; }
  .anim-up    { animation-name:fade-up; }
  .anim-right { animation-name:fade-in-right; }

  /* ─── Hero image clip (angolo tagliate come screenshot) ── */
  .hero-img {
    clip-path: inset(0 0 0 5% round 20px);
  }

  /* ─── Stat number grandi ─────────────────────────── */
  .big-num {
    font-size: 2.8rem; font-weight:900; letter-spacing:-.04em;
    line-height:1; color:oklch(var(--bc));
  }

  /* ─── Dark feature card (come le card dx nel ref) ── */
  .feat-card {
    background:#111827;
    border:1px solid rgba(255,255,255,.07);
    border-radius:1rem;
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .feat-card:hover {
    transform:translateX(5px);
    border-color:rgba(14,165,233,.3);
    box-shadow:-4px 0 20px rgba(14,165,233,.1);
  }

  /* ─── Catalog card ───────────────────────────────── */
  .cat-card { flex-shrink:0; width:240px; position:relative;
              border-radius:1rem; overflow:hidden; cursor:pointer; }
  .cat-card img { width:100%; height:280px; object-fit:cover; display:block;
                  transition:transform .5s ease; }
  .cat-card:hover img { transform:scale(1.05); }
  .cat-card-overlay {
    position:absolute; inset:0;
    background:linear-gradient(to top, rgba(4,8,15,.88) 0%, rgba(4,8,15,.15) 55%, transparent 100%);
    display:flex; flex-direction:column; justify-content:flex-end; padding:1.1rem;
  }

  /* ─── Catalog track (no scrollbar) ──────────────── */
  .cat-track {
    display:flex; gap:.9rem; overflow-x:auto; scroll-behavior:smooth;
    scrollbar-width:none; -ms-overflow-style:none; padding-bottom:.5rem;
  }
  .cat-track::-webkit-scrollbar { display:none; }

  /* ─── Step number watermark ──────────────────────── */
  .step-num {
    font-size:5rem; font-weight:900; letter-spacing:-.06em;
    line-height:1; color:oklch(var(--bc)/.06); user-select:none;
    position:absolute; top:-1rem; left:-.5rem;
  }
</style>

<div class="bg-base-100 text-base-content min-h-screen overflow-x-hidden">

  <%# ══════════════════════════════════════════════════ %>
  <%# SEZIONE 1 ── HERO                                 %>
  <%# Layout: headline · desc · CTA · stats row · foto dx %>
  <%# ══════════════════════════════════════════════════ %>
  <section class="grid grid-cols-1 lg:grid-cols-[1fr_44%] min-h-[90vh] pt-16">

    <%# — colonna sinistra ───────────────────────────── %>
    <div class="flex flex-col px-8 md:px-14 xl:px-20 py-12 lg:py-0 justify-center">

      <%# Headline %>
      <div class="mb-6 anim anim-up" style="animation-delay:.1s;">
        <h1 class="text-[2.6rem] md:text-5xl xl:text-[3.4rem] font-black tracking-tight leading-[1.04]
                   text-base-content mb-5">
          Pillole di saggezza<br>
          per acquaristi seri<br>
          <span class="text-primary">dal 2013</span>
        </h1>
        <p class="text-base-content/45 text-[1rem] font-normal leading-relaxed max-w-md">
          Articoli tecnici scritti da Sergio dopo 20 anni di vasca, centinaia di analisi
          chimiche e oltre 400 acquari progettati da zero.
        </p>
      </div>

      <%# CTA button (stile screenshot: scuro, freccia) %>
      <div class="mb-14 anim anim-up" style="animation-delay:.18s;">
        <button onclick="document.getElementById('catalogo').scrollIntoView({behavior:'smooth'})"
                class="btn btn-neutral rounded-full px-8 gap-3
                       text-[.65rem] tracking-widest uppercase font-bold">
          Leggi gli articoli
        </button>
      </div>

      <%# STAT ROW — esatto come screenshot (3 numeri grandi + label) %>
      <div class="grid grid-cols-3 gap-6 border-t border-base-300 pt-8 anim anim-up"
           style="animation-delay:.26s;">

        <%# Avatar row sopra i numeri (come nel ref) %>
        <div class="col-span-3 flex items-center gap-3 mb-5">
          <div class="avatar-group -space-x-3">
            <% %w[r1 r2 r3].each do |s| %>
              <div class="avatar">
                <div class="w-9 rounded-full border-2 border-base-100">
                  <img src="https://picsum.photos/seed/<%= s %>/40/40" alt=""/>
                </div>
              </div>
            <% end %>
          </div>
          <div>
            <p class="text-xs font-bold">2.400+ lettori</p>
            <p class="text-[.65rem] text-base-content/35">si fidano di Sergio</p>
          </div>
        </div>

        <% [
          { val:"20",  sym:"~", label:"anni esperienza\nmedia Sergio" },
          { val:"3",   sym:"+", label:"articoli nuovi\nogni mese" },
          { val:"180", sym:"+", label:"parametri\nanalizzati" },
        ].each do |s| %>
          <div>
            <div class="big-num flex items-end gap-0.5 mb-1">
              <%= s[:val] %><span class="text-2xl font-black text-primary/60 leading-none mb-1"><%= s[:sym] %></span>
            </div>
            <p class="text-[.67rem] tracking-wide text-base-content/35 leading-snug whitespace-pre-line">
              <%= s[:label] %>
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <%# — colonna destra: immagine clippata ─────────── %>
    <div class="relative hidden lg:block anim anim-right" style="animation-delay:.15s;">
      <div class="hero-img absolute inset-0 overflow-hidden">
        <%= image_tag "coral-reef-premium.jpg", 
             alt: "Acquario Marino Premium", 
             class: "w-full h-full object-cover" %>
        <%# Overlay gradient a sinistra per blend col bg %>
        <div class="absolute inset-0 bg-gradient-to-r from-base-100/40 via-transparent to-transparent"></div>
      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# SEZIONE 2 ── "Scriviamo di acqua…"               %>
  <%# Layout: testo + immagine sx  |  3 dark card dx   %>
  <%# ══════════════════════════════════════════════════ %>
  <section class="py-24 px-8 md:px-14 xl:px-20 bg-base-100">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <%# Sinistra — testo + foto struttura %>
      <div class="anim anim-up" style="animation-delay:.05s;">
        <h2 class="text-4xl xl:text-5xl font-black tracking-tighter leading-[1.02] mb-5">
          Scriviamo di acqua<br>
          con rigore scientifico
        </h2>
        <p class="text-base-content/45 leading-relaxed mb-8 max-w-md">
          Ogni articolo nasce da osservazione diretta, analisi chimica e anni di prove in vasca.
          Nessuna teoria non verificata sul campo, nessuna sponsorizzazione nascosta.
        </p>
        <div class="rounded-2xl overflow-hidden border border-base-300">
          <img src="https://images.unsplash.com/photo-1514907283155-ea5f4094c70c?q=80&w=2670&auto=format&fit=crop" 
               alt="Dettaglio barriera corallina" 
               class="w-full object-cover hover:scale-[1.03] transition-transform duration-700" />
        </div>
      </div>

      <%# Destra — 3 dark card esatte come screenshot %>
      <div class="space-y-3 anim anim-right" style="animation-delay:.1s;">
        <% [
          {
            img: "https://picsum.photos/seed/fc01/80/80",
            titolo: "Alta resistenza chimica",
            desc:   "I parametri non sono numeri astratti. Capire pH, GH, KH e azoto ti permette di prevenire crisi prima che si manifestino.",
            badge: "Fondamentali",
          },
          {
            img: "https://picsum.photos/seed/fc02/80/80",
            titolo: "Piante e fertilizzazione",
            desc:   "Le piante vive regolano l'ecosistema meglio di qualsiasi filtro. Impara macro, micro e il ruolo indispensabile del CO₂.",
            badge: "Botanica",
          },
          {
            img: "https://picsum.photos/seed/fc03/80/80",
            titolo: "Nessuna usura del progetto",
            desc:   "Un acquario ben progettato non invecchia. Scegliamo materiali, layout e specie pensando a dieci anni di stabilità.",
            badge: "Design",
          },
        ].each do |f| %>
          <div class="feat-card flex items-start gap-4 p-4 cursor-pointer">
            <%# Thumbnail come nel reference (piccola immagine bordata) %>
            <div class="w-14 h-14 rounded-xl overflow-hidden shrink-0 border border-white/10">
              <img src="<%= f[:img] %>" alt="" class="w-full h-full object-cover"/>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-white font-black text-[.92rem] tracking-tight mb-1">
                <%= f[:titolo] %>
              </h3>
              <p class="text-white/38 text-[.8rem] leading-relaxed"><%= f[:desc] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# SEZIONE 3 ── CATALOGO ARTICOLI                   %>
  <%# Layout: header (titolo sx + nota dx) · scroll cards · CTA sx + nav frecce dx %>
  <%# ══════════════════════════════════════════════════ %>
  <section id="catalogo" class="py-20 px-8 md:px-14 xl:px-20"
           style="background: oklch(var(--b2)/.5);">
    <div class="max-w-7xl mx-auto">

      <%# Header sezione — identico al reference %>
      <div class="flex items-end justify-between mb-8 flex-wrap gap-4 anim anim-up"
           style="animation-delay:.05s;">
        <div>
          <h2 class="text-3xl md:text-4xl font-black tracking-tighter leading-tight">
            Catalogo degli articoli<br>
            più letti del Journal
          </h2>
        </div>
        <div class="text-right">
          <p class="text-[.78rem] font-bold text-base-content/60">Conoscenza acquaristica</p>
          <p class="text-primary text-[.72rem] font-semibold tracking-wide">sempre aggiornato</p>
        </div>
      </div>

      <%# Scroll track %>
      <%
        articoli_cat = [
          { tag:"Biologia",    col:"error",     titolo:"Perché i pesci boccheggiano?",        sub:"da €0 · Lettura libera", img:"https://picsum.photos/seed/ac01/500/400" },
          { tag:"Aquascaping", col:"success",   titolo:"L'arte della potatura",                sub:"da €0 · 12 min",          img:"https://picsum.photos/seed/ac02/500/400" },
          { tag:"Nutrizione",  col:"warning",   titolo:"Alimentazione consapevole",            sub:"da €0 · 6 min",           img:"https://picsum.photos/seed/ac03/500/400" },
          { tag:"Parametri",   col:"info",      titolo:"Il ciclo dell'azoto spiegato bene",    sub:"da €0 · 10 min",          img:"https://picsum.photos/seed/ac04/500/400" },
          { tag:"Piante",      col:"secondary", titolo:"CO₂ liquida vs gassosa: la verità",   sub:"da €0 · 7 min",           img:"https://picsum.photos/seed/ac05/500/400" },
        ]
      %>
      <div id="cat-track" class="cat-track anim anim-up" style="animation-delay:.1s;">
        <% articoli_cat.each do |a| %>
          <div class="cat-card">
            <img src="<%= a[:img] %>" alt="<%= a[:titolo] %>"/>
            <div class="cat-card-overlay">
              <span class="badge badge-<%= a[:col] %> badge-soft badge-xs
                           tracking-widest uppercase font-bold mb-2">
                <%= a[:tag] %>
              </span>
              <p class="text-white font-black text-[.88rem] tracking-tight leading-snug mb-1">
                <%= a[:titolo] %>
              </p>
              <p class="text-white/40 text-[.72rem]"><%= a[:sub] %></p>
            </div>
          </div>
        <% end %>
      </div>

      <%# Footer sezione — CTA sx + frecce dx (identico ref) %>
      <div class="flex items-center justify-between mt-7 anim anim-up" style="animation-delay:.15s;">
        <%= link_to blog_index_path,
              class: "btn btn-neutral rounded-full px-8 gap-2
                       text-[.65rem] tracking-widest uppercase font-bold" do %>
          Archivio completo
        <% end %>


      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# SEZIONE 4 ── COME SEGUIRCI (4 card = "Pagamento") %>
  <%# Layout: titolo centrato · 4 card in riga          %>
  <%# ══════════════════════════════════════════════════ %>
  <section id="come-seguirci" class="py-24 px-8 md:px-14 xl:px-20 bg-base-100">
    <div class="max-w-7xl mx-auto">

      <h2 class="text-3xl font-black tracking-tighter text-center mb-12 anim anim-up"
          style="animation-delay:0.05s;">
        Come seguire il Journal
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% [
          {
            titolo: "Newsletter",
            desc:   "Collaboriamo con i migliori autori del settore. Ricevi ogni nuovo articolo direttamente in inbox, senza spam, con la possibilità di cancellarti in un click.",
            col:    "primary",
          },
          {
            titolo: "WhatsApp",
            desc:   "Se hai ricevuto un capitale di conoscenza gratuita dal Journal, puoi usarla per migliorare la tua vasca. Seguici per micro-pillole quotidiane.",
            col:    "success",
          },
          {
            titolo: "Podcast",
            desc:   "Lavoriamo con chi vuole approfondire senza leggere. Ogni mese Sergio registra un episodio di 20 minuti su un tema specifico dell'acquariofilia.",
            col:    "secondary",
          },
          {
            titolo: "Archivio PDF",
            desc:   "Puoi scaricare tutti gli articoli per categoria in un PDF ottimizzato. Perfetto da consultare offline mentre curi la tua vasca.",
            col:    "warning",
          },
        ].each_with_index do |m, i| %>
          <%# Card stile screenshot: bordo sottile, arrow btn in basso a destra %>
          <div class="card bg-base-100 border border-base-300 rounded-2xl
                      hover:border-<%= m[:col] %>/35 hover:shadow-lg hover:shadow-<%= m[:col] %>/6
                      hover:-translate-y-0.5 transition-all duration-300
                      anim anim-up" style="animation-delay:<%= 0.05 + i * 0.07 %>s;">
            <div class="card-body p-6 gap-4">
              <h3 class="font-black text-base tracking-tight"><%= m[:titolo] %></h3>
              <p class="text-base-content/45 text-[.82rem] leading-relaxed flex-1"><%= m[:desc] %></p>

            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# NEWSLETTER FOOTER — dark band full width          %>
  <%# ══════════════════════════════════════════════════ %>
  <section class="py-20 px-8 md:px-14 xl:px-20" style="background:#0a0e17;">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-12 justify-between">

      <div class="anim anim-up" style="animation-delay:0.05s;">
        <p class="text-[.65rem] tracking-[.25em] uppercase text-white/25 font-semibold mb-3">Newsletter</p>
        <h2 class="text-4xl font-black tracking-tighter leading-tight text-white mb-3">
          Non perdere<br>i nuovi articoli
        </h2>
        <p class="text-white/30 text-[.95rem] font-light leading-relaxed max-w-sm">
          Ogni nuovo articolo del Journal in inbox.
          Massimo una email a settimana. Cancellati quando vuoi.
        </p>
      </div>

      <div class="w-full lg:max-w-sm anim anim-up" style="animation-delay:0.1s;">
        <div class="space-y-3">
          <input type="text" placeholder="Il tuo nome"
                 class="input w-full rounded-xl bg-white/5 border border-white/8 text-white
                        placeholder:text-white/20 focus:border-primary/40 focus:outline-none text-sm"/>
          <input type="email" placeholder="La tua email"
                 class="input w-full rounded-xl bg-white/5 border border-white/8 text-white
                        placeholder:text-white/20 focus:border-primary/40 focus:outline-none text-sm"/>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" class="checkbox checkbox-primary checkbox-sm mt-0.5"/>
            <span class="text-[.72rem] text-white/25 leading-relaxed">
              Accetto la privacy policy e desidero ricevere la newsletter di Aquaura.
            </span>
          </label>
          <button class="btn btn-primary w-full rounded-xl text-[.65rem] tracking-widest uppercase font-bold">
            Iscriviti al Journal
          </button>
        </div>
      </div>
    </div>
  </section>

</div>

<script>
  // ── IntersectionObserver per tutte le animazioni ───
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.animationPlayState = 'running';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.anim').forEach(el => io.observe(el));
</script>
