<div class="w-full min-h-screen py-24 bg-base-100">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <!-- Hero Galleria -->
    <div class="text-center mb-20 space-y-6" data-controller="scroll-reveal">
      <h3 class="text-xs tracking-[0.2em] font-bold text-primary uppercase">I Nostri Orizzonti</h3>
      <h1 class="text-5xl md:text-6xl font-serif text-white tracking-tight">Galleria del Sommerso.</h1>
      <p class="text-lg text-slate-400 font-light max-w-2xl mx-auto leading-relaxed">
        Frammenti di oceano ricreati in ambienti domestici e professionali.<br>Il risultato tangibile del metodo "Aquaura".
      </p>
    </div>

    <!-- Featured Carousel con DaisyUI -->
    <div class="carousel w-full mb-16 rounded-none" data-controller="scroll-reveal">
      <div id="slide1" class="carousel-item relative w-full">
        <img src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?auto=format&fit=crop&q=80&w=1600&h=900" class="w-full h-[50vh] object-cover" alt="Featured 1"/>
        <div class="absolute inset-0 bg-gradient-to-t from-base-100/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8">
          <h3 class="text-3xl font-serif text-white mb-2">Progetto Iwagumi Master</h3>
          <div class="flex items-center gap-4">
            <div class="rating rating-sm">
              <input type="radio" name="rating-featured-1" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-1" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-1" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-1" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-1" class="mask mask-star-2 bg-primary" checked="checked" disabled />
            </div>
            <span class="badge badge-primary badge-outline">Premium</span>
          </div>
        </div>
        <div class="absolute flex justify-between transform -translate-y-1/2 left-5 right-5 top-1/2">
          <a href="#slide3" class="btn btn-circle btn-ghost">❮</a>
          <a href="#slide2" class="btn btn-circle btn-ghost">❯</a>
        </div>
      </div>
      
      <div id="slide2" class="carousel-item relative w-full">
        <img src="https://images.unsplash.com/photo-1522069213448-443a614da9b6?auto=format&fit=crop&q=80&w=1600&h=900" class="w-full h-[50vh] object-cover" alt="Featured 2"/>
        <div class="absolute inset-0 bg-gradient-to-t from-base-100/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8">
          <h3 class="text-3xl font-serif text-white mb-2">Reef Tank Dream</h3>
          <div class="flex items-center gap-4">
            <div class="rating rating-sm">
              <input type="radio" name="rating-featured-2" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-2" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-2" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-2" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-2" class="mask mask-star-2 bg-primary" disabled />
            </div>
            <span class="badge badge-secondary badge-outline">Reef</span>
          </div>
        </div>
        <div class="absolute flex justify-between transform -translate-y-1/2 left-5 right-5 top-1/2">
          <a href="#slide1" class="btn btn-circle btn-ghost">❮</a>
          <a href="#slide3" class="btn btn-circle btn-ghost">❯</a>
        </div>
      </div>
      
      <div id="slide3" class="carousel-item relative w-full">
        <img src="https://images.unsplash.com/photo-1518684079-3c830dcef090?auto=format&fit=crop&q=80&w=1600&h=900" class="w-full h-[50vh] object-cover" alt="Featured 3"/>
        <div class="absolute inset-0 bg-gradient-to-t from-base-100/90 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8">
          <h3 class="text-3xl font-serif text-white mb-2">Acquario Olandese</h3>
          <div class="flex items-center gap-4">
            <div class="rating rating-sm">
              <input type="radio" name="rating-featured-3" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-3" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-3" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-3" class="mask mask-star-2 bg-primary" checked="checked" disabled />
              <input type="radio" name="rating-featured-3" class="mask mask-star-2 bg-primary" checked="checked" disabled />
            </div>
            <span class="badge badge-accent badge-outline">Olandese</span>
          </div>
        </div>
        <div class="absolute flex justify-between transform -translate-y-1/2 left-5 right-5 top-1/2">
          <a href="#slide2" class="btn btn-circle btn-ghost">❮</a>
          <a href="#slide1" class="btn btn-circle btn-ghost">❯</a>
        </div>
      </div>
    </div>

    <!-- Filtri con DaisyUI Tabs -->
    <div class="tabs tabs-boxed bg-base-200/50 mb-16 w-fit mx-auto opacity-0 translate-y-10 transition-all duration-1000 delay-100" data-controller="scroll-reveal">
      <a class="tab tab-lifted tab-active text-white">Tutti</a>
      <a class="tab tab-lifted text-slate-400">Hardscape</a>
      <a class="tab tab-lifted text-slate-400">Olandese</a>
      <a class="tab tab-lifted text-slate-400">Reef SPS</a>
    </div>

    <!-- Griglia Masonry Fluida Custom -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-8 auto-rows-[250px]">
      <% @images.each_with_index do |image, index| %>
        <div class="group relative overflow-hidden bg-base-200 <%= image[:style] %> cursor-pointer opacity-0 translate-y-10 transition-all duration-1000 ease-out" data-controller="scroll-reveal" style="transition-delay: <%= (index % 5) * 100 %>ms">
          
          <img src="<%= image[:url] %>" alt="<%= image[:title] %>" class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-105 filter grayscale-[20%] group-hover:grayscale-0" />
          
          <div class="absolute inset-0 bg-base-100/20 group-hover:bg-transparent transition-colors duration-500"></div>

          <!-- Badge Categoria -->
          <div class="absolute top-4 left-4">
            <div class="badge badge-outline border-white/30 text-white/80 text-xs uppercase tracking-widest">
              <%= image[:type] %>
            </div>
          </div>

          <!-- Overlay Elegante con Rating -->
          <div class="absolute inset-x-0 bottom-0 p-8 bg-gradient-to-t from-base-100/90 via-base-100/50 to-transparent translate-y-8 group-hover:translate-y-0 transition-transform duration-500 ease-out opacity-0 group-hover:opacity-100">
            <h3 class="text-xl font-serif text-white mb-2 tracking-wide"><%= image[:title] %></h3>
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <span class="w-6 h-px bg-primary"></span>
                <p class="text-xs text-primary uppercase tracking-widest"><%= image[:type] %></p>
              </div>
              <div class="rating rating-xs">
                <input type="radio" name="rating-gallery-<%= index %>" class="mask mask-star-2 bg-primary" checked="checked" disabled />
                <input type="radio" name="rating-gallery-<%= index %>" class="mask mask-star-2 bg-primary" checked="checked" disabled />
                <input type="radio" name="rating-gallery-<%= index %>" class="mask mask-star-2 bg-primary" checked="checked" disabled />
                <input type="radio" name="rating-gallery-<%= index %>" class="mask mask-star-2 bg-primary" checked="checked" disabled />
                <input type="radio" name="rating-gallery-<%= index %>" class="mask mask-star-2 bg-primary" disabled />
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    
  </div>
</div>

