  // ── Apri modal ────────────────────────────────────────
  function openModal(id) {
    const p = progetti[id];
    if (!p) return;
    document.getElementById('modal-img').src       = p.img;
    document.getElementById('modal-img').alt       = p.titolo;
    document.getElementById('modal-titolo').textContent = p.titolo;
    document.getElementById('modal-luogo').textContent  = p.luogo;
    document.getElementById('modal-dim').textContent    = p.dim;
    const badge = document.getElementById('modal-badge');
    badge.textContent  = p.badge;
    badge.className    = `badge ${p.badge_col} badge-soft badge-sm tracking-widest uppercase font-bold mb-2`;
    document.getElementById('photo-modal').showModal();
  }

  // ── Filter ────────────────────────────────────────────
  function filterGallery(cat, btn) {
    // Update active pill
    document.querySelectorAll('.filter-pill').forEach(b => {
      b.classList.remove('active');
      b.classList.add('btn-ghost');
    });
    btn.classList.add('active');
    btn.classList.remove('btn-ghost');

    const items = document.querySelectorAll('.gallery-item');
    let visible = 0;
    items.forEach(item => {
      const match = cat === 'all' || item.dataset.cat === cat;
      if (match) {
        item.style.display = 'block';
        // Re-trigger fade
        item.style.opacity = '0';
        item.style.animationPlayState = 'running';
        setTimeout(() => { item.style.opacity = ''; }, 10);
        visible++;
      } else {
        item.style.display = 'none';
      }
    });
    document.getElementById('empty-state').classList.toggle('hidden', visible > 0);
  }

  // ── Toggle view masonry/grid ──────────────────────────
  function setView(type, btn) {
    const grid = document.getElementById('masonry-grid');
    document.querySelectorAll('#view-masonry, #view-grid').forEach(b => b.classList.remove('btn-active'));
    btn.classList.add('btn-active');
    if (type === 'grid') {
      grid.className = 'grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5';
      grid.querySelectorAll('.masonry-item').forEach(el => {
        el.style.marginBottom = '0';
        el.querySelector('img').style.height = '220px';
      });
    } else {
      grid.className = 'masonry-grid';
      grid.querySelectorAll('.masonry-item').forEach(el => {
        el.style.marginBottom = '';
        el.querySelector('img').style.height = '';
      });
    }
  }

  // ── Like toggle ───────────────────────────────────────
  function toggleLike(btn, id) {
    const liked = btn.dataset.liked === 'true';
    btn.dataset.liked = !liked;
    const svg = btn.querySelector('svg');
    svg.setAttribute('fill', liked ? 'none' : 'currentColor');
    svg.style.color = liked ? '' : '#f87171';
    btn.classList.add('like-pop');
    setTimeout(() => btn.classList.remove('like-pop'), 350);
    const counter = document.getElementById('likes-' + id);
    if (counter) counter.textContent = parseInt(counter.textContent) + (liked ? -1 : 1);
  }

  // ── IntersectionObserver fade-up ─────────────────────
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.animationPlayState = 'running';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));
</script>
