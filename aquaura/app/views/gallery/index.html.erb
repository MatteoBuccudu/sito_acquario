<%# ══════════════════════════════════════════════════════
    Galleria — Collezione Aquaura
    DaisyUI 5 + Tailwind + Masonry CSS + 3D Hover JS
══════════════════════════════════════════════════════ %>

<style>
  /* ── Masonry layout con CSS columns ── */
  .masonry-grid {
    column-count: 1;
    column-gap: 1.25rem;
  }
  @media (min-width: 640px)  { .masonry-grid { column-count: 2; } }
  @media (min-width: 1024px) { .masonry-grid { column-count: 3; } }
  @media (min-width: 1280px) { .masonry-grid { column-count: 4; } }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 1.25rem;
    display: block;
  }

  /* ── Hover overlay su ogni foto ── */
  .photo-card { position: relative; overflow: hidden; cursor: pointer; }
  .photo-card img {
    display: block; width: 100%; transition: transform 0.5s cubic-bezier(0.32,0.72,0,1);
  }
  .photo-card:hover img { transform: scale(1.07); }
  .photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(4,8,15,0.9) 0%, rgba(4,8,15,0.2) 50%, transparent 100%);
    opacity: 0; transition: opacity 0.35s ease;
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 1.25rem;
  }
  .photo-card:hover .photo-overlay { opacity: 1; }
  .photo-overlay-top {
    position: absolute; top: 0; left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 1rem; opacity: 0; transform: translateY(-6px);
    transition: opacity 0.35s ease 0.05s, transform 0.35s ease 0.05s;
  }
  .photo-card:hover .photo-overlay-top { opacity: 1; transform: translateY(0); }
  .photo-overlay-body {
    opacity: 0; transform: translateY(8px);
    transition: opacity 0.35s ease 0.08s, transform 0.35s ease 0.08s;
  }
  .photo-card:hover .photo-overlay-body { opacity: 1; transform: translateY(0); }

  /* ── Shimmer hero ── */
  @keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }
  .shimmer-text {
    background: linear-gradient(90deg, oklch(var(--p)) 0%, oklch(var(--s)) 40%, oklch(var(--a)) 70%, oklch(var(--p)) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; animation: shimmer 5s linear infinite;
  }

  /* ── Fade up ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { opacity: 0; animation: fade-up 0.7s ease forwards; animation-play-state: paused; }

  /* ── Bubble float ── */
  @keyframes bubble {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
    50%       { transform: translateY(-18px) scale(1.1); opacity: 0.6; }
  }
  .bubble-anim { animation: bubble ease-in-out infinite; }

  /* ── Modal zoom-in ── */
  dialog::backdrop { background: rgba(4,8,15,0.92); backdrop-filter: blur(8px); }
  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.94) translateY(12px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  dialog[open] { animation: modal-in 0.3s cubic-bezier(0.32,0.72,0,1) both; }

  /* ── Filter pill active ── */
  .filter-pill.active {
    background: oklch(var(--p));
    color: oklch(var(--pc));
    border-color: oklch(var(--p));
  }

  /* ── Spin slow decorativo ── */
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .spin-slow { animation: spin-slow 22s linear infinite; }

  /* ── Like animation ── */
  @keyframes like-pop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }
  .like-pop { animation: like-pop 0.35s cubic-bezier(0.36, 0.07, 0.19, 0.97); }
</style>

<div class="min-h-screen bg-base-100 overflow-x-hidden">

  <%# ── HERO ─────────────────────────────────────────── %>
  <section class="relative pt-28 pb-14 px-6 overflow-hidden">
    <div class="spin-slow absolute top-20 right-10 w-56 h-56 rounded-full border border-primary/8 hidden lg:block pointer-events-none"></div>
    <div class="spin-slow absolute top-32 right-20 w-36 h-36 rounded-full border border-secondary/8 hidden lg:block pointer-events-none" style="animation-direction:reverse;animation-duration:16s;"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[320px] rounded-full bg-primary/5 blur-3xl pointer-events-none"></div>

    <% [[8,4,6],[20,3,5],[35,5,8],[65,4,7],[79,3,5],[91,6,9]].each_with_index do |(l,s,d),i| %>
      <div class="bubble-anim absolute bottom-4 rounded-full bg-primary/20 pointer-events-none"
           style="left:<%= l %>%;width:<%= s %>px;height:<%= s %>px;animation-duration:<%= d %>s;animation-delay:<%= i*0.8 %>s;"></div>
    <% end %>

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="badge badge-primary badge-outline badge-lg mb-8 fade-up" style="animation-delay:0.05s;">
        ✦ Ecosistemi Realizzati
      </div>
      <h1 class="text-6xl lg:text-7xl font-black tracking-tighter mb-4 leading-[0.9] fade-up" style="animation-delay:0.15s;">
        La nostra<br><span class="text-primary">Collezione</span>
      </h1>
      <p class="text-base-content/50 text-xl font-light leading-relaxed max-w-xl mx-auto mb-10 fade-up" style="animation-delay:0.3s;">
        Ogni acquario è un ecosistema vivo. Ogni foto racconta mesi di equilibri,
        di cura e di conoscenza sedimentata.
      </p>

      <%# Stats %>
      <div class="stats stats-horizontal bg-base-200/60 border border-base-300 rounded-3xl shadow backdrop-blur-sm fade-up" style="animation-delay:0.45s;">
        <div class="stat place-items-center px-7">
          <div class="stat-value text-primary text-2xl">47</div>
          <div class="stat-desc tracking-widest uppercase text-xs">Progetti</div>
        </div>
        <div class="stat place-items-center px-7">
          <div class="stat-value text-secondary text-2xl">12</div>
          <div class="stat-desc tracking-widest uppercase text-xs">Categorie</div>
        </div>
        <div class="stat place-items-center px-7">
          <div class="stat-value text-accent text-2xl">100%</div>
          <div class="stat-desc tracking-widest uppercase text-xs">Clienti soddisfatti</div>
        </div>
      </div>
    </div>
  </section>

  <%# ── FILTER BAR ─────────────────────────────────────── %>
  <div class="max-w-7xl mx-auto px-6 mb-10 fade-up" style="animation-delay:0.1s;">
    <div class="flex items-center gap-3 flex-wrap">
      <span class="text-[0.6rem] tracking-[0.25em] uppercase text-base-content/30 font-semibold shrink-0">Filtra per</span>
      <% [
        { label:"Tutti",           cat:"all",        active: true },
        { label:"Nature Aquarium", cat:"nature",     active: false },
        { label:"Biotopo",         cat:"biotopo",    active: false },
        { label:"Discus",          cat:"discus",     active: false },
        { label:"Aquascaping",     cat:"aquascape",  active: false },
        { label:"Commerciale",     cat:"commercial", active: false },
        { label:"Nano",            cat:"nano",       active: false },
      ].each do |f| %>
        <button
          class="filter-pill btn btn-sm rounded-full border border-base-300
                 text-[0.65rem] tracking-widest uppercase font-bold
                 hover:border-primary/40 hover:text-primary transition-all duration-200
                 <%= f[:active] ? 'active' : 'btn-ghost' %>"
          data-filter="<%= f[:cat] %>"
          onclick="filterGallery('<%= f[:cat] %>', this)"
        >
          <%= f[:label] %>
        </button>
      <% end %>

      <div class="ml-auto flex items-center gap-2">
        <span class="text-[0.6rem] tracking-[0.25em] uppercase text-base-content/30 font-semibold">Vista</span>
        <div class="join">
          <button id="view-masonry" onclick="setView('masonry', this)"
                  class="btn btn-xs join-item rounded-l-xl border border-base-300 btn-active tooltip"
                  data-tip="Masonry">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
              <rect x="0" y="0" width="6" height="10" rx="1"/><rect x="8" y="0" width="6" height="6" rx="1"/>
              <rect x="0" y="12" width="6" height="4" rx="1"/><rect x="8" y="8" width="6" height="8" rx="1"/>
            </svg>
          </button>
          <button id="view-grid" onclick="setView('grid', this)"
                  class="btn btn-xs join-item rounded-r-xl border border-base-300 tooltip"
                  data-tip="Griglia">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
              <rect x="0" y="0" width="6" height="6" rx="1"/><rect x="8" y="0" width="6" height="6" rx="1"/>
              <rect x="0" y="8" width="6" height="6" rx="1"/><rect x="8" y="8" width="6" height="6" rx="1"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <%# ── MASONRY GALLERY ─────────────────────────────────── %>
  <%
    progetti = [
      { id:1,  cat:"nature",     titolo:"Foresta di HC Cuba",         luogo:"Milano, Residenziale",  dim:"200L",  img:"https://images.unsplash.com/photo-1522069169874-c58ec4b76be5?w=800&q=80",  h:"tall",   likes:124, badge:"Nature Aquarium", badge_col:"success" },
      { id:2,  cat:"discus",     titolo:"Discus Paradise",            luogo:"Roma, Studio Privato",  dim:"600L",  img:"https://images.unsplash.com/photo-1535591273668-578e31182c4f?w=800&q=80",  h:"medium", likes:89,  badge:"Discus",         badge_col:"error" },
      { id:3,  cat:"aquascape",  titolo:"Iwagumi Minimalista",        luogo:"Torino, Appartamento",  dim:"120L",  img:"https://images.unsplash.com/photo-1504472478235-9bc48ba4d60f?w=800&q=80",  h:"medium", likes:203, badge:"Aquascaping",    badge_col:"primary" },
      { id:4,  cat:"commercial", titolo:"Reception Tower",            luogo:"Milano, Hotel 5★",      dim:"2000L", img:"https://images.unsplash.com/photo-1582967788606-a171c1080cb0?w=800&q=80",  h:"tall",   likes:341, badge:"Commerciale",    badge_col:"secondary" },
      { id:5,  cat:"nano",       titolo:"Nano Shrimp Garden",         luogo:"Firenze, Home Office",  dim:"30L",   img:"https://images.unsplash.com/photo-1559827291-72ee739d0d9a?w=800&q=80",  h:"short",  likes:67,  badge:"Nano",           badge_col:"accent" },
      { id:6,  cat:"biotopo",    titolo:"Amazon Blackwater",          luogo:"Bologna, Villa",        dim:"400L",  img:"https://images.unsplash.com/photo-1524704654690-b56c05c78a00?w=800&q=80",  h:"medium", likes:156, badge:"Biotopo",        badge_col:"warning" },
      { id:7,  cat:"nature",     titolo:"Vallesneria Gigante",        luogo:"Venezia, Albergo",      dim:"350L",  img:"https://images.unsplash.com/photo-1514907283155-ea5f4094c70c?w=800&q=80",  h:"tall",   likes:98,  badge:"Nature Aquarium",badge_col:"success" },
      { id:8,  cat:"aquascape",  titolo:"Dragon Stone Landscape",     luogo:"Genova, Ufficio",       dim:"180L",  img:"https://images.unsplash.com/photo-1516408388733-2f8364f2e00b?w=800&q=80",  h:"short",  likes:177, badge:"Aquascaping",    badge_col:"primary" },
      { id:9,  cat:"commercial", titolo:"Ristorante Oceanico",        luogo:"Napoli, Ristorante",    dim:"800L",  img:"https://images.unsplash.com/photo-1520301255226-bf5f144451c1?w=800&q=80",  h:"medium", likes:289, badge:"Commerciale",    badge_col:"secondary" },
      { id:10, cat:"discus",     titolo:"Royal Blue Discus Suite",    luogo:"Palermo, Villa",        dim:"500L",  img:"https://images.unsplash.com/photo-1576330383200-2bf325cfec52?w=800&q=80",  h:"tall",   likes:212, badge:"Discus",         badge_col:"error" },
      { id:11, cat:"nano",       titolo:"Cube Microsorum",            luogo:"Padova, Bedroom",       dim:"20L",   img:"https://images.unsplash.com/photo-1522720833375-9c27ffb02a5e?w=800&q=80",  h:"short",  likes:44,  badge:"Nano",           badge_col:"accent" },
      { id:12, cat:"biotopo",    titolo:"Tanganyika Cichlid",         luogo:"Verona, Salotto",       dim:"300L",  img:"https://images.unsplash.com/photo-1599488615731-7e5c2823ff28?w=800&q=80",  h:"medium", likes:133, badge:"Biotopo",        badge_col:"warning" },
    ]
  %>

  <div id="gallery-container" class="max-w-7xl mx-auto px-6 pb-20">
    <div id="masonry-grid" class="masonry-grid">
      <% progetti.each_with_index do |p, i| %>
        <div class="masonry-item gallery-item fade-up"
             data-cat="<%= p[:cat] %>"
             data-id="<%= p[:id] %>"
             style="animation-delay:<%= (i % 8) * 0.07 %>s;">
          <div class="photo-card rounded-2xl overflow-hidden border border-base-300
                      hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/10
                      transition-all duration-500"
               onclick="openModal(<%= p[:id] %>)">

            <%# Immagine con altezza variabile %>
            <img
              src="<%= p[:img] %>"
              alt="<%= p[:titolo] %>"
              class="w-full object-cover"
              style="<%= p[:h] == 'tall' ? 'height:340px' : p[:h] == 'short' ? 'height:200px' : 'height:260px' %>"
              loading="lazy"
            />

            <%# Top overlay: badge + like %>
            <div class="photo-overlay-top">
              <span class="badge badge-<%= p[:badge_col] %> badge-sm font-bold tracking-widest uppercase shadow-lg">
                <%= p[:badge] %>
              </span>
              <button
                onclick="event.stopPropagation(); toggleLike(this, <%= p[:id] %>)"
                class="btn btn-circle btn-xs bg-base-100/20 border-0 text-white hover:bg-base-100/40 backdrop-blur-sm"
                data-liked="false"
              >
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </button>
            </div>

            <%# Bottom overlay: info %>
            <div class="photo-overlay">
              <div class="photo-overlay-body">
                <p class="text-[0.6rem] tracking-[0.2em] uppercase text-white/50 font-semibold mb-1">
                  <%= p[:dim] %> · <%= p[:luogo] %>
                </p>
                <h3 class="text-white font-black tracking-tight text-base leading-tight mb-3">
                  <%= p[:titolo] %>
                </h3>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5 text-white/60 text-xs">
                    <svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <span id="likes-<%= p[:id] %>"><%= p[:likes] %></span>
                  </div>
                  <span class="text-[0.6rem] tracking-widest uppercase text-white/40 font-semibold">
                    Vedi dettagli →
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# Empty state (nascosto di default) %>
    <div id="empty-state" class="hidden text-center py-24">
      <p class="text-5xl mb-4">🐠</p>
      <p class="text-base-content/40 text-lg font-light">Nessun progetto in questa categoria... ancora.</p>
    </div>
  </div>

  <%# ── CAROUSEL PREMI E RICONOSCIMENTI ─────────────────── %>
  <div class="max-w-7xl mx-auto px-6 mb-20">
    <div class="divider divider-primary opacity-30 mb-8">
      <span class="text-[0.65rem] tracking-[0.3em] uppercase text-base-content/30 font-semibold">Riconoscimenti</span>
    </div>
    <div class="carousel carousel-center gap-5 py-4 px-2">
      <% [
        { ico:"🏆", titolo:"Best Nature Aquarium",   anno:"ADA Italia 2024", sub:"Categoria residenziale 200-500L" },
        { ico:"🥇", titolo:"Top Design Award",       anno:"Aqua Expo 2023",  sub:"Allestimento commerciale" },
        { ico:"⭐", titolo:"Excellence in Biotope",  anno:"CIPS 2023",       sub:"Amazon Blackwater Setup" },
        { ico:"🎖️", titolo:"Aquascaping Champion",  anno:"IAPLC 2022",      sub:"Top 50 mondiale" },
      ].each do |p| %>
        <div class="carousel-item">
          <div class="card bg-base-200 border border-base-300 w-64
                      hover:border-primary/30 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5
                      transition-all duration-300">
            <div class="card-body p-6 items-center text-center gap-2">
              <span class="text-4xl mb-1"><%= p[:ico] %></span>
              <h4 class="font-black text-sm text-base-content leading-tight"><%= p[:titolo] %></h4>
              <span class="badge badge-primary badge-soft badge-xs tracking-widest uppercase font-bold"><%= p[:anno] %></span>
              <p class="text-xs text-base-content/40"><%= p[:sub] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── CTA FINALE ──────────────────────────────────────── %>
  <div class="max-w-4xl mx-auto px-6 pb-24 text-center fade-up" style="animation-delay:0.1s;">
    <div class="card bg-base-200 border border-primary/20 hover:border-primary/40
                hover:shadow-2xl hover:shadow-primary/8 transition-all duration-500">
      <div class="card-body py-14 px-8 items-center gap-6">
        <p class="text-5xl">🌊</p>
        <div>
          <h2 class="text-3xl font-black tracking-tight text-base-content mb-2">
            Vuoi il tuo ecosistema?
          </h2>
          <p class="text-base-content/50 text-base font-light max-w-md">
            Raccontaci il tuo spazio. Progettiamo insieme un acquario che sembri
            sempre esistito lì.
          </p>
        </div>
        <div class="card-actions gap-3">
          <%= link_to root_path(anchor:"contatti"),
                class: "btn btn-primary rounded-2xl px-8 text-[0.65rem] tracking-widest uppercase font-bold" do %>
            Inizia il progetto →
          <% end %>
          <%= link_to shop_path,
                class: "btn btn-ghost rounded-2xl px-8 text-[0.65rem] tracking-widest uppercase font-bold border border-base-300" do %>
            Esplora i kit
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# ══ MODAL ════════════════════════════════════════════════ %>
<dialog id="photo-modal" class="modal">
  <div class="modal-box bg-base-200 border border-base-300 max-w-4xl p-0 overflow-hidden rounded-3xl">
    <div class="flex flex-col lg:flex-row max-h-[85vh]">

      <%# Immagine %>
      <div class="lg:w-3/5 shrink-0 overflow-hidden">
        <img id="modal-img" src="" alt="" class="w-full h-64 lg:h-full object-cover"/>
      </div>

      <%# Info panel %>
      <div class="flex-1 flex flex-col p-7 overflow-y-auto">
        <div class="flex items-start justify-between mb-4">
          <div>
            <span id="modal-badge" class="badge badge-primary badge-soft badge-sm tracking-widest uppercase font-bold mb-2"></span>
            <h2 id="modal-titolo" class="text-2xl font-black tracking-tight text-base-content"></h2>
          </div>
          <form method="dialog">
            <button class="btn btn-ghost btn-sm btn-circle border border-base-300 hover:border-error/30 hover:text-error transition-colors">✕</button>
          </form>
        </div>

        <div class="space-y-4 flex-1">
          <div class="stats stats-vertical bg-base-300/50 rounded-2xl">
            <div class="stat py-3">
              <div class="stat-title text-xs">Ubicazione</div>
              <div id="modal-luogo" class="stat-value text-base font-bold text-base-content"></div>
            </div>
            <div class="stat py-3">
              <div class="stat-title text-xs">Volume vasca</div>
              <div id="modal-dim" class="stat-value text-base font-bold text-primary"></div>
            </div>
          </div>

          <%# Dettagli tecnici fake %>
          <div>
            <p class="text-[0.6rem] tracking-[0.2em] uppercase text-base-content/30 font-semibold mb-3">Specifiche tecniche</p>
            <ul class="steps steps-vertical text-xs">
              <li class="step step-primary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">Filtrazione a zona multipla</span></li>
              <li class="step step-primary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">Sistema CO₂ a diffusore in-line</span></li>
              <li class="step step-primary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">Illuminazione LED programmabile</span></li>
              <li class="step step-primary" data-content="✓"><span class="ml-2 text-xs text-base-content/70">Manutenzione mensile inclusa</span></li>
            </ul>
          </div>
        </div>

        <div class="mt-6 pt-5 border-t border-base-300 flex items-center gap-3">
          <%= link_to root_path(anchor:"contatti"),
                class: "btn btn-primary btn-sm rounded-xl flex-1 text-[0.65rem] tracking-widest uppercase font-bold" do %>
            Progetto simile →
          <% end %>
          <button onclick="document.getElementById('photo-modal').close()"
                  class="btn btn-ghost btn-sm rounded-xl border border-base-300 text-[0.65rem] tracking-widest uppercase">
            Chiudi
          </button>
        </div>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  // ── Dati galleria per modal ────────────────────────────
  const progetti = {
