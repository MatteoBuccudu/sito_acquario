<script>
  // ── 3D Tilt ─────────────────────────────────────────
  document.querySelectorAll('[data-tilt]').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const rx = ((e.clientY - r.top  - r.height/2) / (r.height/2)) * -7;
      const ry = ((e.clientX - r.left - r.width /2) / (r.width /2)) *  7;
      card.style.transform = `perspective(1100px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.015,1.015,1.015)`;
      card.style.boxShadow = `${-ry*3}px ${rx*3}px 45px rgba(0,0,0,0.16)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform .5s ease, box-shadow .5s ease';
      card.style.transform  = 'perspective(1100px) rotateX(0) rotateY(0) scale3d(1,1,1)';
      card.style.boxShadow  = '';
      setTimeout(() => { card.style.transition = ''; }, 500);
    });
  });

  // ── Drag to scroll per galleria ───────────────────
  const gallery = document.getElementById('sv-gallery');
  let isDown = false;
  let startX;
  let scrollLeft;

  gallery.addEventListener('mousedown', (e) => {
    isDown = true;
    gallery.classList.add('active');
    startX = e.pageX - gallery.offsetLeft;
    scrollLeft = gallery.scrollLeft;
  });
  gallery.addEventListener('mouseleave', () => {
    isDown = false;
    gallery.classList.remove('active');
  });
  gallery.addEventListener('mouseup', () => {
    isDown = true; // Wait, actually false
    isDown = false;
    gallery.classList.remove('active');
  });
  gallery.addEventListener('mousemove', (e) => {
    if(!isDown) return;
    e.preventDefault();
    const x = e.pageX - gallery.offsetLeft;
    const walk = (x - startX) * 2; // velocità scroll
    gallery.scrollLeft = scrollLeft - walk;
  });

  // ── IntersectionObserver ─────────────────────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.animationPlayState = 'running';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.anim').forEach(el => io.observe(el));

  // ── Countdown live ───────────────────────────────────
  function tick() {
    const now = new Date();
    const h = 23 - now.getHours();
    const m = 59 - now.getMinutes();
    document.querySelectorAll('[aria-label$="ore"] span').forEach(s => { s.style.setProperty('--value', h); s.textContent = h; });
    document.querySelectorAll('[aria-label$="min"] span').forEach(s => { s.style.setProperty('--value', m); s.textContent = m; });
  }
  tick();
  setInterval(tick, 60000);
</script>
