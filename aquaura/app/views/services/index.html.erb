            img_alt:"Acquario marino con coralli",
            lista:["Visita mensile fissa con check completo","Pulizia e verifica impianto filtrante","Reperibilità h24 su WhatsApp inclusa","Sconto 20% su prodotti e interventi extra"],
            prezzo:"da € 60/mese", step_col:"step-secondary",
            rating:5, recensioni:112,
            tag:"Abbonamento",
          },
        ]
      %>

      <% servizi.each_with_index do |s, idx| %>
        <div class="tilt anim anim-up" data-tilt
             style="animation-delay:<%= 0.05 + idx * 0.08 %>s;">
          <div class="card sm:card-side bg-base-200 border border-base-300
                      hover:border-<%= s[:colore] %>/30 hover:shadow-2xl hover:shadow-<%= s[:colore] %>/6
                      overflow-hidden transition-all duration-400"
               style="transform-style:preserve-3d;">

            <%# Immagine laterale con INDICATOR %>
            <figure class="sm:w-72 shrink-0 relative overflow-hidden">
              <img src="<%= s[:img] %>"
                   alt="<%= s[:img_alt] %>"
                   class="w-full h-56 sm:h-full object-cover
                          hover:scale-[1.04] transition-transform duration-700"/>
              <%# BADGE numero + tag sopra immagine %>
              <div class="absolute top-4 left-4 flex flex-col gap-2">
                <span class="badge badge-neutral bg-base-100/80 backdrop-blur-sm
                             font-mono text-xs border border-base-300">
                  <%= s[:num] %>
                </span>
                <span class="badge badge-<%= s[:colore] %> badge-sm font-bold
                             tracking-widest uppercase">
                  <%= s[:tag] %>
                </span>
              </div>
              <%# Rating overlay in basso %>
              <div class="absolute bottom-4 left-4">
              </div>
            </figure>

            <%# Body %>
            <div class="card-body p-7 gap-5" style="transform:translateZ(8px);">
              <div>
                <h2 class="card-title text-xl font-black tracking-tight leading-snug mb-1">
                  <%= s[:titolo] %>
                </h2>
                <p class="text-base-content/40 text-sm italic"><%= s[:sotto] %></p>
              </div>

              <div class="hidden md:block">
                <p class="text-base-content/55 text-sm leading-relaxed"><%= s[:desc] %></p>
              </div>

              <div class="divider divider-<%= s[:colore] %> my-0 opacity-20"></div>

              <%# STEPS verticali checkout-style %>
              <ul class="steps steps-vertical text-xs">
                <% s[:lista].each_with_index do |voce, vi| %>
                  <li class="step <%= s[:step_col] %>" data-content="<%= vi + 1 %>">
                    <span class="text-left text-xs text-base-content/65 ml-2"><%= voce %></span>
                  </li>
                <% end %>
              </ul>

              <div class="card-actions items-center justify-between mt-auto pt-2 border-t border-base-200 flex-wrap gap-3">
                <div>
                  <p class="text-[.58rem] tracking-widest uppercase text-base-content/25">Tariffa</p>
                  <p class="text-2xl font-black text-<%= s[:colore] %>"><%= s[:prezzo] %></p>
                </div>
                <div class="join">
                  <button class="btn btn-ghost btn-sm join-item rounded-l-xl border border-base-300
                                 tooltip tooltip-top" data-tip="Salva nei preferiti">
                    Salva
                  </button>
                  <div class="dropdown dropdown-top dropdown-end">
                    <div tabindex="0" role="button"
                         class="btn btn-ghost btn-sm join-item border border-base-300 border-l-0
                                text-[.62rem] tracking-widest uppercase font-bold">
                      Opzioni
                    </div>
                    <ul tabindex="0" class="dropdown-content menu bg-base-200 border border-base-300
                                            rounded-2xl shadow-xl w-52 p-2 z-20">
                      <li><a class="text-xs">Richiedi preventivo</a></li>
                      <li><a class="text-xs">Prenota visita</a></li>
                      <li><a class="text-xs">Consulenza WhatsApp</a></li>
                    </ul>
                  </div>
                  <%= link_to root_path(anchor:"contatti"),
                        class:"btn btn-#{s[:colore]} btn-sm join-item rounded-r-xl px-6
                                text-[.65rem] tracking-widest uppercase font-bold" do %>
                    Prenota
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# 4 ── "Interveniamo su…" testo + dark feat card   %>
  <%# ══════════════════════════════════════════════════ %>
