  <section id="servizi-grid" class="px-8 md:px-14 xl:px-20 pb-24 bg-base-100">
    <div class="max-w-7xl mx-auto space-y-6">
      <%
        servizi = [
          {
            num:"01", colore:"primary",
            titolo:"Check-up Chimico Completo",
            sotto:"Il tuo acquario sotto analisi professionale",
            desc:"Analizziamo 12 parametri con fotometro professionale. Ti consegniamo un report PDF con il piano correttivo personalizzato, consultabile in qualsiasi momento.",
            img:"https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=600&q=80",
            img_alt:"Acquario con pesci colorati analizzato",
            lista:["12 parametri: NH₃, NO₂, NO₃, PO₄, GH, KH, pH, CO₂, O₂, Fe, Mg, Ca","Fotometro professionale — non striscette","Report PDF con piano correttivo step-by-step","Consulenza post-analisi 48h inclusa"],
            prezzo:"da € 89", step_col:"step-primary",
            rating:5, recensioni:48,
            tag:"Diagnostica",
          },
          {
            num:"02", colore:"success",
            titolo:"Potatura & Aquascaping",
            sotto:"Le piante hanno preso il sopravvento?",
            desc:"Potatura selettiva con forbici curve professionali, riposizionamento di rocce e radici, trattamento antialghe. Restituiamo al layout il suo equilibrio originale.",
            img:"https://images.unsplash.com/photo-1522069169874-c58ec4b76be5?w=600&q=80",
            img_alt:"Acquario planted con piante acquatiche",
            lista:["Potatura selettiva con forbici curve professionali","Riposizionamento rocce, radici e substrate","Trattamento antialghe post-intervento","Report fotografico prima/dopo incluso"],
            prezzo:"da € 120", step_col:"step-success",
            rating:5, recensioni:73,
            tag:"Piante",
          },
          {
            num:"03", colore:"warning",
            titolo:"Trasloco Acquario",
            sotto:"Sposti casa? Pensiamo a tutto noi.",
            desc:"Dal confezionamento dei pesci con sacchetti O₂ puro al riallestimento nella nuova sede: gestiamo ogni fase per eliminare lo shock osmotico e ridurre lo stress.",
            img:"https://images.unsplash.com/photo-1524704654690-b56c05c78a00?w=600&q=80",
            img_alt:"Acquario di grandi dimensioni installato",
            lista:["Sacchetti professionali con ossigeno puro","Contenitori termici per trasporti lunghi","Riallestimento completo nella nuova sede","Monitoraggio parametri nelle 48h successive"],
            prezzo:"da € 200", step_col:"step-warning",
            rating:5, recensioni:31,
            tag:"Trasloco",
          },
          {
            num:"04", colore:"secondary",
            titolo:"Contratto Manutenzione Mensile",
            sotto:"La tranquillità di chi sa che qualcuno pensa alla sua vasca",
            desc:"Visita mensile fissa con check parametri, pulizia filtro, regolazione impianti. Più reperibilità h24 su WhatsApp per qualsiasi emergenza nel mezzo.",
