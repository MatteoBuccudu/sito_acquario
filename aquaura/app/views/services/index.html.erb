<div class="relative w-full min-h-screen py-24 flex flex-col items-center overflow-hidden bg-base-100">
  
  <div class="container mx-auto px-6 max-w-7xl relative z-10 flex flex-col lg:flex-row gap-16">
    
    <!-- Left Column: Info, Steps, Accordion -->
    <div class="w-full lg:w-1/2 space-y-16 opacity-0 translate-y-10 transition-all duration-1000" data-controller="scroll-reveal">
      
      <!-- Intestazione -->
      <div class="space-y-6">
        <h1 class="text-4xl md:text-5xl font-serif text-base-content tracking-tight">SOS Sergio.</h1>
        <p class="text-base-content/60 text-lg leading-relaxed">Dai setup iniziali alle emergenze critiche. Qui rassicuriamo il cliente: il tuo ecosistema è in mani esperte.</p>
      </div>

      <!-- DaisyUI Steps (Come Lavoriamo) -->
      <div class="space-y-6 opacity-0 translate-y-10 transition-all duration-1000 delay-200" data-controller="scroll-reveal">
        <h3 class="text-xs tracking-[0.2em] font-bold text-base-content uppercase opacity-50 border-b border-base-content/10 pb-4">
          Il Nostro Protocollo
        </h3>
        
        <!-- DaisyUI Steps Vertical -->
        <ul class="steps steps-vertical w-full">
          <li class="step step-primary">
            <div class="text-left">
              <h4 class="text-base-content font-serif">Audit e Analisi Chimica</h4>
              <p class="text-base-content/50 text-sm">Fase 1 - Test fotometrici completi e valutazione dello stato dell'ecosistema</p>
            </div>
          </li>
          <li class="step step-primary">
            <div class="text-left">
              <h4 class="text-base-content font-serif">Bonifica e Settaggio</h4>
              <p class="text-base-content/50 text-sm">Fase 2 - Interventi correttivi e preparazione dell'ambiente</p>
            </div>
          </li>
          <li class="step">
            <div class="text-left">
              <h4 class="text-base-content/40 font-serif">Mantenimento e Monitoraggio</h4>
              <p class="text-base-content/30 text-sm">Fase 3 - Cure periodiche e report digitali</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- FAQ con DaisyUI Collapse -->
      <div class="space-y-4 opacity-0 translate-y-10 transition-all duration-1000 delay-300" data-controller="scroll-reveal">
        <h3 class="text-xs tracking-[0.2em] font-bold text-base-content uppercase opacity-50 border-b border-base-content/10 pb-4 mb-4">
          Servizi di Eccellenza
        </h3>
        
        <div class="collapse collapse-arrow border border-base-content/10 bg-base-200 rounded-none">
          <input type="radio" name="my-accordion-2" checked="checked" /> 
          <div class="collapse-title text-lg font-serif text-base-content">
            Check-up Chimico Completo
          </div>
          <div class="collapse-content text-base-content/60 font-light text-sm"> 
            <p>Analizziamo 12 parametri dell'acqua con fotometro professionale. Ti consegniamo un report digitale con le correzioni da apportare per un equilibrio perfetto.</p>
          </div>
        </div>
        
        <div class="collapse collapse-arrow border border-base-content/10 bg-base-200 rounded-none">
          <input type="radio" name="my-accordion-2" /> 
          <div class="collapse-title text-lg font-serif text-base-content">
            Potatura e Aquascaping
          </div>
          <div class="collapse-content text-base-content/60 font-light text-sm"> 
            <p>Le tue piante hanno preso il sopravvento? Veniamo a potare, riordinare e rinvigorire il tuo layout, mantenendo lo stile originale e la salute delle specie.</p>
          </div>
        </div>
        
        <div class="collapse collapse-arrow border border-base-content/10 bg-base-200 rounded-none">
          <input type="radio" name="my-accordion-2" /> 
          <div class="collapse-title text-lg font-serif text-base-content">
            Trasloco Acquario
          </div>
          <div class="collapse-content text-base-content/60 font-light text-sm"> 
            <p>Sposti casa? Gestiamo noi il trasporto dei pesci in sicurezza e il riallestimento tecnico della vasca, evitando lo shock osmotico agli abitanti.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Glassmorphism Form -->
    <div class="w-full lg:w-1/2 opacity-0 translate-y-10 transition-all duration-1000 delay-300" data-controller="scroll-reveal">
      
      <% if flash[:success] %>
        <div class="toast toast-top toast-center z-50">
          <div class="alert alert-success shadow-xl animate-fade-in-down rounded-none border border-base-content/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span><%= flash[:success] %></span>
          </div>
        </div>
      <% end %>

      <!-- Glassmorphism Form con DaisyUI -->
      <div class="relative bg-base-200/50 backdrop-blur-3xl border border-base-content/5 p-8 md:p-12 shadow-2xl">
        <div class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>
        
        <h3 class="text-2xl font-serif text-base-content mb-8 border-b border-base-content/10 pb-4">Richiedi Intervento</h3>

        <%= form_with url: servizi_path, method: :post, class: "space-y-6" do |f| %>
          <!-- Floating Label Input con DaisyUI -->
          <div class="form-control w-full">
            <%= f.label :nome, "Nominativo", class: "label" do %>
              <span class="label-text-alt text-base-content/60 tracking-widest text-xs uppercase">Nominativo</span>
            <% end %>
            <%= f.text_field :nome, required: true, class: "input input-lg input-bordered w-full bg-base-300/50 border-base-content/10 text-base-content focus:outline-none focus:border-primary transition-colors rounded-none", placeholder: "Es: Mario Rossi" %>
          </div>

          <div class="form-control w-full">
            <%= f.label :telefono, "Contatto Veloce", class: "label" do %>
              <span class="label-text-alt text-base-content/60 tracking-widest text-xs uppercase">Contatto Veloce</span>
            <% end %>
            <%= f.telephone_field :telefono, required: true, class: "input input-lg input-bordered w-full bg-base-300/50 border-base-content/10 text-base-content focus:outline-none focus:border-primary transition-colors rounded-none", placeholder: "+39 ..." %>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="form-control w-full">
              <%= f.label :tipo, "Servizio", class: "label" do %>
                <span class="label-text-alt text-base-content/60 tracking-widest text-xs uppercase">Servizio</span>
              <% end %>
              <%= f.select :tipo, ["Check-up Chimico Completo", "Potatura e Aquascaping", "Trasloco Acquario"], { prompt: "Seleziona..." }, class: "select select-lg select-bordered w-full bg-base-300/50 border-base-content/10 text-base-content focus:outline-none focus:border-primary rounded-none" %>
            </div>

            <div class="form-control w-full">
              <%= f.label :data_richiesta, "Data Preferita", class: "label" do %>
                <span class="label-text-alt text-base-content/60 tracking-widest text-xs uppercase">Data Preferita</span>
              <% end %>
              <%= f.date_field :data_richiesta, data: { controller: "datepicker" }, class: "input input-lg input-bordered w-full bg-base-300/50 border-base-content/10 text-base-content focus:outline-none focus:border-primary rounded-none", required: true %>
            </div>
          </div>

          <div class="form-control w-full pt-4">
            <%= f.label :descrizione, "Dettagli Eccezione", class: "label" do %>
              <span class="label-text-alt text-base-content/60 tracking-widest text-xs uppercase">Dettagli</span>
            <% end %>
            <%= f.text_area :descrizione, rows: 4, class: "textarea textarea-lg textarea-bordered w-full bg-base-300/50 border-base-content/10 text-base-content focus:outline-none focus:border-primary resize-none rounded-none", placeholder: "Descrivi gentilmente cosa la preoccupa dell'ecosistema..." %>
          </div>

          <div class="mt-8 pt-6 border-t border-base-content/5">
            <!-- DaisyUI Button con loading state -->
            <%= f.submit "Conferma Prenotazione", class: "btn btn-primary btn-block btn-lg rounded-none uppercase tracking-widest font-semibold" %>
          </div>
        <% end %>

      </div>
    </div>
  </div>
</div>

