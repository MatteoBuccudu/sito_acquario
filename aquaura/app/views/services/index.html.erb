            <div class="stat-title text-xs">Monitoraggio incluso</div>
            <div class="stat-desc text-[.65rem]">post ogni intervento</div>
          </div>
          <div class="stat py-4 place-items-center">
            <div class="stat-value text-warning text-2xl">4.9</div>
            <div class="stat-title text-xs">★ Valutazione media</div>
            <div class="stat-desc text-[.65rem]">su 400+ interventi</div>
          </div>
        </div>
