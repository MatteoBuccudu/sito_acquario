                   alt="Acquario prima" class="object-cover w-full h-full"/>
            </div>
            <div class="diff-item-2">
              <img src="https://images.unsplash.com/photo-1551244072-5d12893278bc?w=700&q=80"
                   alt="Acquario dopo" class="object-cover w-full h-full"/>
            </div>
            <div class="diff-resizer"></div>
          </figure>
        </div>
        <p class="text-[.65rem] tracking-[.2em] uppercase text-base-content/25 font-semibold mt-2 text-center">
          <h2 class="text-4xl xl:text-5xl font-black tracking-tighter leading-[1.02] mb-5">
            Interveniamo<br>
            su qualsiasi<br>
            <span class="text-primary">problema</span>
          </h2>
        </p>
      </div>

      <div class="space-y-3 anim anim-left" style="animation-delay:.1s;">
