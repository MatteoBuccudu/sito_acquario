  <%# ══════════════════════════════════════════════════ %>
  <%# 6 ── COME FUNZIONA (4 card + STEPS orizzontali)  %>
  <%# ══════════════════════════════════════════════════ %>
  <section class="py-24 px-8 md:px-14 xl:px-20"
           style="background:oklch(var(--b2)/.4);">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-black tracking-tighter text-center mb-4 anim anim-up"
          style="animation-delay:.05s;">Come prenotare un intervento</h2>
      <p class="text-base-content/40 text-center mb-12 anim anim-up" style="animation-delay:.1s;">
        Dal primo messaggio al report finale: ecco esattamente cosa succede.
      </p>

      <%# STEPS orizzontale DaisyUI %>
      <ul class="steps steps-horizontal w-full mb-14 anim anim-up" style="animation-delay:.12s;">
        <li class="step step-primary"><span class="mt-3 text-xs text-base-content/60">Diagnosi gratis</span></li>
        <li class="step step-primary"><span class="mt-3 text-xs text-base-content/60">Preventivo fisso</span></li>
        <li class="step step-secondary"><span class="mt-3 text-xs text-base-content/60">Intervento</span></li>
        <li class="step"><span class="mt-3 text-xs text-base-content/60">Report PDF</span></li>
        <li class="step"><span class="mt-3 text-xs text-base-content/60">7gg monitoraggio</span></li>
      </ul>

      <%# 4 card processo %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% [
          { titolo:"Diagnosi gratuita",   col:"primary",   desc:"Scrivi su WhatsApp. Sergio risponde entro 10 minuti con la prima valutazione. Zero costi fino all'intervento." },
          { titolo:"Preventivo fisso",    col:"success",   desc:"Il prezzo viene concordato prima della visita. Dettaglio voce per voce, nessuna sorpresa in fattura." },
          { titolo:"Intervento in vasca", col:"secondary", desc:"Sergio arriva con strumenti professionali. Ogni passaggio viene documentato in tempo reale." },
          { titolo:"Monitoraggio post",   col:"warning",   desc:"7 giorni di contatto diretto post intervento. Se qualcosa non va, si ritorna senza costi aggiuntivi." },
        ].each_with_index do |m, i| %>
          <div class="card bg-base-100 border border-base-300 rounded-2xl
                      hover:border-<%= m[:col] %>/35 hover:shadow-lg hover:shadow-<%= m[:col] %>/6
                      hover:-translate-y-0.5 transition-all duration-300
                      anim anim-up" style="animation-delay:<%= 0.05 + i * 0.07 %>s;">
            <div class="card-body p-6 gap-4">
              <h3 class="font-black text-base tracking-tight"><%= m[:titolo] %></h3>
              <p class="text-base-content/45 text-[.82rem] leading-relaxed flex-1"><%= m[:desc] %></p>
              <div class="flex justify-end">
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# 7 ── TRE FASI + COUNTDOWN PROSSIMI SLOT          %>
