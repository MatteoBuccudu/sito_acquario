

<style>
  /* ── Animazioni ── */
  @keyframes fade-up {
    from { opacity:0; transform:translateY(22px); }
    to   { opacity:1; transform:translateY(0); }
  }
  @keyframes fade-right {
    from { opacity:0; transform:translateX(-26px); }
    to   { opacity:1; transform:translateX(0); }
  }
  @keyframes fade-left {
    from { opacity:0; transform:translateX(26px); }
    to   { opacity:1; transform:translateX(0); }
  }
  .anim { opacity:0; animation-duration:.65s; animation-fill-mode:both;
          animation-timing-function:cubic-bezier(.22,.68,0,1.2);
          animation-play-state:paused; }
  .anim-up    { animation-name:fade-up; }
  .anim-right { animation-name:fade-right; }
  .anim-left  { animation-name:fade-left; }

  /* ── Hero clip ── */
  .hero-clip { clip-path: inset(0 0 0 5% round 24px); }

  /* ── Big stat ── */
  .big-num {
    font-size:2.8rem; font-weight:900;
    letter-spacing:-.04em; line-height:1;
  }

  /* ── Dark feat card ── */
  .feat-card {
    background:#111827;
    border:1px solid rgba(255,255,255,.07);
    border-radius:1rem;
    transition:transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }
  .feat-card:hover {
    transform:translateX(5px);
    border-color:rgba(14,165,233,.3);
    box-shadow:-4px 0 20px rgba(14,165,233,.1);
  }

  /* ── Catalog scroll ── */
  .cat-track {
    display:flex; gap:1rem; overflow-x:auto;
    scroll-behavior:smooth; scrollbar-width:none; padding-bottom:.5rem;
  }
  .cat-track::-webkit-scrollbar { display:none; }
  .cat-card { flex-shrink:0; width:270px; position:relative;
              border-radius:1rem; overflow:hidden; cursor:pointer; }
  .cat-card img { width:100%; height:310px; object-fit:cover; display:block;
                  transition:transform .5s ease; }
  .cat-card:hover img { transform:scale(1.05); }
  .cat-overlay {
    position:absolute; inset:0;
    background:linear-gradient(to top,rgba(4,8,15,.9) 0%,rgba(4,8,15,.2) 55%,transparent 100%);
    display:flex; flex-direction:column; justify-content:flex-end; padding:1.1rem;
  }



  /* ── Pulse ring ── */
  @keyframes pulse-ring {
    0%   { box-shadow:0 0 0 0 oklch(var(--er)/.45); }
    70%  { box-shadow:0 0 0 12px oklch(var(--er)/0); }
    100% { box-shadow:0 0 0 0 oklch(var(--er)/0); }
  }
  .sos-pulse { animation:pulse-ring 2.5s ease-in-out infinite; }

  /* ── Tilt 3D ── */
  .tilt { transform-style:preserve-3d; will-change:transform; }





  /* ── Diff aspect ── */
  .diff-wrap { aspect-ratio:16/9; }
</style>

<div class="bg-base-100 text-base-content min-h-screen overflow-x-hidden">




  <%# ══════════════════════════════════════════════════ %>
  <%# 2 ── ALERT URGENZA + TABS FILTRO                 %>
  <%# ══════════════════════════════════════════════════ %>
  <section class="px-8 md:px-14 xl:px-20 py-10 bg-base-100">
    <div class="max-w-7xl mx-auto space-y-5">

      <%# ALERT urgenza %>
      <div role="alert" class="alert alert-warning alert-soft sm:alert-horizontal rounded-2xl anim anim-up"
           style="animation-delay:.05s;">
        <span class="text-sm"><strong>Emergenza in corso?</strong> Sergio risponde su WhatsApp entro 10 minuti, 7 giorni su 7, anche di notte.</span>
        <a href="#" class="btn btn-warning btn-sm rounded-xl text-[.65rem] tracking-widest uppercase font-bold">Scrivi ora</a>
      </div>

      <%# TABS — filtro categoria %>
      <div class="tabs tabs-box anim anim-up" style="animation-delay:.1s;" role="tablist">
        <input type="radio" name="sv-tabs" class="tab text-[.65rem] tracking-widest uppercase font-bold" aria-label="Tutti" checked/>
        <div class="tab-content pt-2"></div>
        <input type="radio" name="sv-tabs" class="tab text-[.65rem] tracking-widest uppercase font-bold" aria-label="Diagnostica"/>
        <div class="tab-content pt-2"></div>
        <input type="radio" name="sv-tabs" class="tab text-[.65rem] tracking-widest uppercase font-bold" aria-label="Piante"/>
        <div class="tab-content pt-2"></div>
        <input type="radio" name="sv-tabs" class="tab text-[.65rem] tracking-widest uppercase font-bold" aria-label="Trasloco"/>
        <div class="tab-content pt-2"></div>
        <input type="radio" name="sv-tabs" class="tab text-[.65rem] tracking-widest uppercase font-bold" aria-label="Abbonamento"/>
        <div class="tab-content pt-2"></div>
      </div>
    </div>
  </section>


  <%# ══════════════════════════════════════════════════ %>
  <%# 3 ── GRID SERVIZI (card orizzontali con immagine) %>
