</dialog>


<script>
  // ── IntersectionObserver ─────────────────────────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.animationPlayState = 'running';
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.anim').forEach(el => io.observe(el));

  // ── Countdown live ───────────────────────────────────────
  function tickCountdown() {
    const now = new Date();
    const h = 23 - now.getHours();
    const m = 59 - now.getMinutes();
    const hEl = document.getElementById('cd-hrs');
    const mEl = document.getElementById('cd-min');
    if (hEl) { hEl.style.setProperty('--value', h); hEl.textContent = h; }
    if (mEl) { mEl.style.setProperty('--value', m); mEl.textContent = m; }
  }
  tickCountdown();
  setInterval(tickCountdown, 60000);

  // ── Form submit feedback ─────────────────────────────────
  document.querySelector('form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = this.querySelector('[type="submit"]');
    if (!btn) return;
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ Inviato! Sergio risponderà entro 10 minuti';
    btn.classList.add('btn-success');
    btn.classList.remove('btn-primary');
    btn.disabled = true;
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.classList.remove('btn-success');
      btn.classList.add('btn-primary');
      btn.disabled = false;
    }, 5000);
  });
</script>
