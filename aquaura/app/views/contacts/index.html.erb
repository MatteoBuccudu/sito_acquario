      <% end %>
      <div class="divider opacity-20"></div>
      <div class="card bg-base-300/50 border border-base-300 rounded-xl">
        <div class="card-body p-4 gap-1">
          <p class="text-xs font-bold">Orari attivi</p>
          <p class="text-[.72rem] text-base-content/45">Lun–Ven 9:00–18:00</p>
          <p class="text-[.72rem] text-base-content/45">WhatsApp 8:00–22:00</p>
        </div>
      </div>
    </div>
  </div>
</div><%# fine drawer %>


